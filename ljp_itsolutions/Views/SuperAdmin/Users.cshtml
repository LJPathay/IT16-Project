@model IEnumerable<ljp_itsolutions.Models.User>
@using ljp_itsolutions.Helpers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Role & User Management";
    var roles = ViewBag.Roles as IEnumerable<string> ?? Enumerable.Empty<string>();
}

<div class="container-fluid py-2">
    <!-- Action Bar -->
    <div class="row g-3 mb-4 align-items-center">
        <div class="col-md-4">
            <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                <span class="input-group-text bg-white border-0 ps-3">
                    <i class="fas fa-search text-muted"></i>
                </span>
                <input type="text" id="userSearch" class="form-control border-0 shadow-none ps-2 py-2" placeholder="Search by name or username..." aria-label="Search users by name or username">
            </div>
        </div>
        <div class="col-md-3">
            <select id="roleFilter" class="form-select shadow-sm rounded-pill border py-2" aria-label="Filter by access role">
                <option value="">All Access Roles</option>
                @foreach (var role in roles)
                {
                    <option value="@role">@role</option>
                }
            </select>
        </div>
        <div class="col-md-5 text-end">
            <div class="d-flex gap-2 justify-content-end">
                @if (ViewBag.ShowArchived == true)
                {
                    <a href="@Url.Action("Users", new { showArchived = false })" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="fas fa-users-cog me-2"></i>Active Personnel
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Users", new { showArchived = true })" class="btn btn-light border rounded-pill px-4">
                        <i class="fas fa-archive me-2 text-muted"></i>Archived
                    </a>
                    <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addUserModal">
                        <i class="fas fa-plus-circle me-2"></i>Create User
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0 table-hover" id="usersTable">
                    <thead class="bg-light bg-opacity-50">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase x-small fw-bold text-muted">Full Name</th>
                            <th class="py-3 text-uppercase x-small fw-bold text-muted">Account Identifiers</th>
                            <th class="py-3 text-uppercase x-small fw-bold text-muted">System Role</th>
                            <th class="py-3 text-uppercase x-small fw-bold text-muted text-center">Security Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr class="user-row" data-role="@user.Role" style="cursor: pointer;" 
                                onclick="openEditUserModal('@user.UserID', '@user.FullName', '@user.Username', '@user.Email', '@user.Role', @user.IsActive.ToString().ToLower())" onkeypress="if(event.key === 'Enter') this.click()">
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-sm rounded-circle d-flex align-items-center justify-content-center fw-bold text-white shadow-sm" 
                                             style="background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)); width: 38px; height: 38px;">
                                            @(user.FullName?.Substring(0, 1) ?? "U")
                                        </div>
                                        <div class="user-info">
                                            <p class="mb-0 fw-bold text-dark">@user.FullName</p>
                                            <p class="text-muted x-small mb-0">Member since @user.CreatedAt.ToString("MMM yyyy")</p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small">
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <i class="fas fa-user-circle text-muted x-small"></i>
                                            <span class="user-search-content fw-medium">@SecurityHelper.MaskUsername(user.Username)</span>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="fas fa-envelope text-muted x-small"></i>
                                            <span class="text-muted">@(string.IsNullOrEmpty(user.Email) ? "No email linked" : SecurityHelper.MaskEmail(user.Email))</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 caps">
                                        @user.Role
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (user.IsActive)
                                    {
                                        <span class="badge rounded-pill bg-success px-3">ACTIVE</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger px-3">ARCHIVED</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <partial name="_Pagination" model='("usersTable", "startRange", "endRange", "totalItems", "pagination")' />
    </div>
</div>
</div>

<!-- Modals (Refined) -->
<div class="modal fade" id="addUserModal" tabindex="-1" style="z-index: 2000;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-light border-0 pb-0 pt-4 px-4">
                <h5 class="fw-bold text-dark"><i class="fas fa-user-plus text-primary me-2"></i>Provision New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addUserForm">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="add-fullname" class="form-label x-small fw-bold text-muted">Legal Full Name</label>
                            <input type="text" name="FullName" id="add-fullname" class="form-control rounded-3" placeholder="e.g. John Doe" required aria-label="Full legal name">
                        </div>
                        <div class="col-md-6">
                            <label for="add-username" class="form-label x-small fw-bold text-muted">Account Username</label>
                            <input type="text" name="Username" id="add-username" class="form-control rounded-3" placeholder="unique_handler" required aria-label="Account username">
                        </div>
                        <div class="col-md-6">
                            <label for="add-email" class="form-label x-small fw-bold text-muted">Email</label>
                            <input type="email" name="Email" id="add-email" class="form-control rounded-3" placeholder="user@coffee.local" required aria-label="Email address">
                        </div>
                        <div class="col-12">
                            <label for="add-role" class="form-label x-small fw-bold text-muted">Security Role Assignment</label>
                            <select name="Role" id="add-role" class="form-select rounded-3" required aria-label="Security role assignment">
                                @foreach (var role in roles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="add-password" class="form-label x-small fw-bold text-muted">Initial Access Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3"><i class="fas fa-lock x-small"></i></span>
                                <input type="password" name="Password" id="add-password" class="form-control border-start-0 rounded-end-3" required aria-label="Initial access password">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4" id="btnAddUser">Initialize Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Success Modal -->
<div class="modal fade" id="successModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body text-center p-5">
                <div class="avatar-lg bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                    <i class="fas fa-check-circle fa-3x"></i>
                </div>
                <h4 class="fw-bold text-dark mb-2">Success!</h4>
                <p class="text-muted mb-4">The personnel account has been created successfully.</p>
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-primary rounded-pill fw-bold" onclick="location.reload()">Done</button>
                    <button type="button" class="btn btn-light rounded-pill fw-bold" onclick="resetAndAddAnother()">Add Another</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editUserModal" tabindex="-1" style="z-index: 2000;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-light border-0 pb-0 pt-4 px-4">
                <h5 class="fw-bold text-dark"><i class="fas fa-user-edit text-warning me-2"></i>Update Personnel Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="EditUser" method="post" id="editUserForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="UserID" id="edit-userid" />
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="edit-fullname" class="form-label x-small fw-bold text-muted">Full Name</label>
                            <input type="text" name="FullName" id="edit-fullname" class="form-control rounded-3" required aria-label="Update full name">
                        </div>
                        <div class="col-md-6">
                            <label for="edit-username" class="form-label x-small fw-bold text-muted">Username</label>
                            <input type="text" name="Username" id="edit-username" class="form-control rounded-3" required aria-label="Update username">
                        </div>
                        <div class="col-md-6">
                            <label for="edit-email" class="form-label x-small fw-bold text-muted">Email</label>
                            <input type="email" name="Email" id="edit-email" class="form-control rounded-3" required aria-label="Update email address">
                        </div>
                        <div class="col-12">
                            <label for="edit-role" class="form-label x-small fw-bold text-muted">Role Assignment</label>
                            <select name="Role" id="edit-role" class="form-select rounded-3" required aria-label="Update security role">
                                @foreach (var role in roles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch p-2 bg-light rounded-3 ms-2">
                                <input type="checkbox" name="IsActive" id="edit-isactive" value="true" class="form-check-input ms-0 me-2" checked aria-label="Enable account access">
                                <input type="hidden" name="IsActive" value="false">
                                <label for="edit-isactive" class="form-check-label fw-bold small">Enable Account Access</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0 d-flex justify-content-between">
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3" onclick="confirmArchive()">
                            <i class="fas fa-archive me-1"></i>Archive
                        </button>
                        <button type="button" class="btn btn-outline-warning btn-sm rounded-pill px-3" onclick="triggerReset()">
                            <i class="fas fa-key me-1"></i>Reset Pass
                        </button>
                    </div>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Commit Changes</button>
                </div>
            </form>
            <form id="archiveForm" asp-action="ArchiveUser" method="post" style="display:none;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="archive-userid" />
            </form>
        </div>
    </div>
</div>

<script>
    function confirmArchive() {
        if (confirm('Are you sure you want to archive this user? They will be moved to the Archived_Users table.')) {
            $('#archive-userid').val($('#edit-userid').val());
            $('#archiveForm').submit();
        }
    }

    async function triggerReset() {
        const userId = $('#edit-userid').val();
        if(!confirm('Force a password reset for this user? They will be required to change it on their next login.')) return;
        
        try {
            const res = await fetch('@Url.Action("ResetUserPassword", "SuperAdmin")?userId=' + userId, {
                method: 'POST',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').first().val() }
            });
            if(res.ok) {
                const data = await res.json();
                alert(data.message);
                editModal.hide();
            } else {
                alert('Failed to trigger reset. User might be a SuperAdmin or not found.');
            }
        } catch(err) {
            alert('Error connecting to server.');
        }
    }
</script>

@section Scripts {
    <partial name="_PaginationScripts" model='("usersTable", "user-row", "startRange", "endRange", "totalItems", "pagination", 10)' />
    <script>
        const addUserModal = new bootstrap.Modal(document.getElementById('addUserModal'));
        const successModal = new bootstrap.Modal(document.getElementById('successModal'));
        const editModal = new bootstrap.Modal(document.getElementById('editUserModal'));

        window.openEditUserModal = function(id, fullname, username, email, role, isActive) {
            $('#edit-userid').val(id);
            $('#edit-fullname').val(fullname);
            $('#edit-username').val(username);
            $('#edit-email').val(email);
            $('#edit-role').val(role);
            $('#edit-isactive').prop('checked', isActive);
            editModal.show();
        };

        $('#addUserForm').on('submit', async function(e) {
            e.preventDefault();
            const btn = $('#btnAddUser');
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Processing...');

            const data = {
                FullName: $('#add-fullname').val(),
                Username: $('#add-username').val(),
                Email: $('#add-email').val(),
                Role: $('#add-role').val(),
                Password: $('#add-password').val()
            };

            try {
                const res = await fetch('@Url.Action("CreateUser", "SuperAdmin")', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').first().val()
                    },
                    body: JSON.stringify(data)
                });

                if (res.ok) {
                    addUserModal.hide();
                    successModal.show();
                } else {
                    const err = await res.text();
                    alert(err || 'Failed to create user. Use unique identifiers.');
                }
            } catch (err) {
                alert('Connection error. Please try again.');
            } finally {
                btn.prop('disabled', false).html('Initialize Account');
            }
        });

        window.resetAndAddAnother = function() {
            $('#addUserForm')[0].reset();
            successModal.hide();
            addUserModal.show();
        };

        $(document).ready(function() {
            initPagination();

            // Search and Filter Logic
            function filterUsers() {
                var searchTerm = $('#userSearch').val().toLowerCase();
                var roleFilterValue = $('#roleFilter').val();
                var allRows = Array.from(document.querySelectorAll('.user-row'));

                const filtered = allRows.filter(function(row) {
                    var $row = $(row);
                    var fullName = $row.find('.user-info p.fw-bold').text().toLowerCase();
                    var username = $row.find('.user-search-content').text().toLowerCase();
                    var userRole = $row.data('role');

                    var matchesSearch = fullName.includes(searchTerm) || username.includes(searchTerm);
                    var matchesRole = roleFilterValue === "" || userRole === roleFilterValue;

                    return matchesSearch && matchesRole;
                });

                window.paginationControl.update(filtered);

                if (filtered.length === 0) {
                    if ($('#noResultsRow').length === 0) {
                        $('#usersTable tbody').append('<tr id="noResultsRow"><td colspan="5" class="text-center py-5 text-muted"><i class="fas fa-user-slash fa-3x mb-3 opacity-25"></i><p>No personnel matching your criteria were found.</p></td></tr>');
                    }
                } else {
                    $('#noResultsRow').remove();
                }
            }

            $('#userSearch').on('keyup', filterUsers);
            $('#roleFilter').on('change', filterUsers);
        });
    </script>
}

<style>
    .hvr-danger:hover {
        background-color: var(--danger-color) !important;
        color: white !important;
        border-color: var(--danger-color) !important;
    }
    .x-small { font-size: 0.75rem; }
    .uppercase { text-transform: uppercase; }
    .caps { text-transform: uppercase; }
    .modal-title { color: #1a1a1a !important; font-weight: 700; }
</style>
