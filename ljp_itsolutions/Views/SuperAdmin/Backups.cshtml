@model IEnumerable<System.IO.FileInfo>
@{
    Layout = "_Layout";
    ViewData["Title"] = "System Snapshot & Backups";
}

<div class="container-fluid py-2">
    <!-- Header Section -->
    <div class="row align-items-center mb-5">
        <div class="col">
            <div class="d-flex align-items-center gap-3">
                <div class="avatar-sm rounded-circle bg-success bg-opacity-10 text-success d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                    <i class="fas fa-database fa-lg"></i>
                </div>
                <div>
                    <p class="text-muted small mb-0">Secure manual recovery points for system records and configurations.</p>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <form asp-action="CreateBackup" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="fas fa-plus-circle me-2"></i>Create New Snapshot
                </button>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h6 class="fw-bold text-dark mb-3"><i class="fas fa-clock text-primary me-2"></i>Automated Backup Strategy</h6>
            <form asp-action="UpdateBackupSchedule" method="post" class="d-flex align-items-center gap-3">
                @Html.AntiForgeryToken()
                <select name="schedule" class="form-select w-auto shadow-none" aria-label="schedule">
                    <option value="Manual" selected="@(ViewBag.BackupSchedule == "Manual" ? "selected" : null)">Manual Backups Only</option>
                    <option value="Daily" selected="@(ViewBag.BackupSchedule == "Daily" ? "selected" : null)">Daily Automation</option>
                    <option value="Weekly" selected="@(ViewBag.BackupSchedule == "Weekly" ? "selected" : null)">Weekly Automation (Weekend)</option>
                    <option value="Monthly" selected="@(ViewBag.BackupSchedule == "Monthly" ? "selected" : null)">Monthly Automation</option>
                </select>
                <button type="submit" class="btn btn-outline-secondary px-4"><i class="fas fa-save me-2"></i>Save Policy</button>
                <div class="text-muted small ms-2"><i class="fas fa-info-circle me-1"></i>Automated backup routine processes are strictly globally enforced via the system's global configuration.</div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase x-small fw-bold text-muted">Snapshot Filename</th>
                            <th class="py-3 text-uppercase x-small fw-bold text-muted">Creation Timestamp</th>
                            <th class="py-3 text-uppercase x-small fw-bold text-muted">Storage Size</th>
                            <th class="pe-4 py-3 text-end text-uppercase x-small fw-bold text-muted">Operations</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var file in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <i class="fas fa-file-code text-primary opacity-50"></i>
                                            <span class="fw-bold text-dark">@file.Name</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="small">
                                            <div class="fw-medium text-dark">@file.CreationTime.ToString("MMM dd, yyyy")</div>
                                            <div class="text-muted x-small">at @file.CreationTime.ToString("HH:mm:ss")</div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-light text-dark border px-3">
                                            @((file.Length / 1024.0).ToString("N2")) KB
                                        </span>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a href="@Url.Action("DownloadBackup", "SuperAdmin", new { fileName = file.Name })" class="btn btn-sm btn-light rounded-pill px-3 shadow-none border-0">
                                                <i class="fas fa-download me-1 x-small"></i> Download
                                            </a>
                                            <form asp-action="DeleteBackup" method="post" onsubmit="return confirm('Delete this snapshot permanentely?')" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="fileName" value="@file.Name" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 ms-1">
                                                    Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="fas fa-archive fa-3x mb-3 opacity-25"></i>
                                        <p>No system snapshots have been created yet.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .x-small { font-size: 0.75rem; }
</style>
