@model Dictionary<string, string>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Global System Configuration";
    string GetVal(string key, string defaultVal = "") => Model.ContainsKey(key) ? Model[key] : defaultVal;
    bool GetBool(string key) => Model.ContainsKey(key) && (Model[key].ToLower() == "true" || Model[key].ToLower() == "on");
}

<div class="container-fluid py-4">
    <form asp-action="UpdateSettings" method="post">
        @Html.AntiForgeryToken()
        
        <div class="d-flex justify-content-between align-items-center mb-5 bg-white p-4 rounded-4 shadow-sm border-left-premium">
            <div>
                <h4 class="fw-900 text-dark mb-1">Global System Configuration</h4>
                <p class="text-muted small mb-0"><i class="fas fa-globe-americas me-1 text-primary"></i> Master controls for system-wide policies, localization, and security.</p>
            </div>
            <div class="d-flex gap-3">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" onclick="location.reload()">
                    <i class="fas fa-undo me-2"></i>Reset
                </button>
                <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm fw-bold">
                    <i class="fas fa-save me-2"></i>Apply Changes
                </button>
            </div>
        </div>

        <div class="row g-4">
            <!-- Business Identity Card -->
            <div class="col-xl-4 col-md-6">
                <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden config-card">
                    <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-box bg-danger-soft text-danger me-3">
                                <i class="fas fa-exclamation-triangle"></i>
                            </div>
                            <h6 class="fw-800 mb-0">Critical Business Needs</h6>
                        </div>
                    </div>
                    <div class="card-body p-4 pt-2">
                        <div class="mb-3">
                            <label class="form-label x-small fw-bold text-muted uppercase tracking-wider">Urgent Stock Priority Threshold</label>
                            <div class="input-group">
                                <input type="number" name="CriticalStockThreshold" class="form-control rounded-start-3" value="@GetVal("CriticalStockThreshold", "5")">
                                <span class="input-group-text bg-light border-0 x-small">units</span>
                            </div>
                            <div class="x-small text-danger mt-1 opacity-75">Alerts trigger instantly when inventory drops below this mark.</div>
                        </div>
                        <div class="p-3 rounded-4 bg-light border border-light-2 mb-3">
                            <div class="form-check form-switch mb-2">
                                <input type="checkbox" name="AllowPaymentBypass" class="form-check-input mt-1" value="on" @(GetBool("AllowPaymentBypass") ? "checked" : "")>
                                <label class="form-check-label small fw-bold">Emergency Payment Bypass</label>
                            </div>
                            <div class="x-small text-muted">Allow checkouts to proceed even if payment APIs are offline.</div>
                        </div>
                        <div class="mb-0">
                            <label class="form-label x-small fw-bold text-muted uppercase tracking-wider">System Brand Tagline</label>
                            <input type="text" name="SystemTagline" class="form-control rounded-3" value="@GetVal("SystemTagline", "Premium Coffee Experience")">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Localization & Financials -->
            <div class="col-xl-4 col-md-6">
                <div class="card border-0 shadow-sm h-100 rounded-4 config-card">
                    <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-box bg-success-soft text-success me-3">
                                <i class="fas fa-coins"></i>
                            </div>
                            <h6 class="fw-800 mb-0">Market & Localization</h6>
                        </div>
                    </div>
                    <div class="card-body p-4 pt-2">
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label class="form-label x-small fw-bold text-muted uppercase tracking-wider">Currency Symbol</label>
                                <input type="text" name="Currency" class="form-control rounded-3 text-center fw-900 font-monospace" value="@GetVal("Currency", "₱")">
                            </div>
                            <div class="col-6">
                                <label class="form-label x-small fw-bold text-muted uppercase tracking-wider">Tax Rate (%)</label>
                                <div class="input-group">
                                    <input type="number" step="0.01" name="TaxRate" class="form-control rounded-start-3" value="@GetVal("TaxRate", "5")">
                                    <span class="input-group-text bg-light border-0 x-small">%</span>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label x-small fw-bold text-muted uppercase tracking-wider">System Timezone</label>
                            <select name="Timezone" class="form-select rounded-3">
                                <option value="Asia/Manila" selected="@(GetVal("Timezone") == "Asia/Manila")">Asia/Manila (UTC+8)</option>
                                <option value="UTC" selected="@(GetVal("Timezone") == "UTC")">UTC / GMT</option>
                                <option value="Asia/Singapore" selected="@(GetVal("Timezone") == "Asia/Singapore")">Asia/Singapore</option>
                                <option value="America/New_York" selected="@(GetVal("Timezone") == "America/New_York")">US Eastern Time</option>
                            </select>
                        </div>
                        <div>
                            <label class="form-label x-small fw-bold text-muted uppercase tracking-wider">Date Format</label>
                            <select name="DateFormat" class="form-select rounded-3">
                                <option value="MMM dd, yyyy" selected="@(GetVal("DateFormat") == "MMM dd, yyyy")">MMM dd, yyyy (e.g. Mar 03, 2026)</option>
                                <option value="dd/MM/yyyy" selected="@(GetVal("DateFormat") == "dd/MM/yyyy")">dd/MM/yyyy</option>
                                <option value="MM/dd/yyyy" selected="@(GetVal("DateFormat") == "MM/dd/yyyy")">MM/dd/yyyy</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Network & Communications -->
            <div class="col-xl-4 col-md-6">
                <div class="card border-0 shadow-sm h-100 rounded-4 config-card">
                    <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-box bg-info-soft text-info me-3">
                                <i class="fas fa-envelope-open-text"></i>
                            </div>
                            <h6 class="fw-800 mb-0">Connectivity</h6>
                        </div>
                    </div>
                    <div class="card-body p-4 pt-2">
                        <div class="mb-3">
                            <label class="form-label x-small fw-bold text-muted uppercase tracking-wider">SMTP Server</label>
                            <input type="text" name="SmtpServer" class="form-control rounded-3" value="@GetVal("SmtpServer")" placeholder="smtp.gmail.com">
                        </div>
                        <div class="mb-3">
                            <label class="form-label x-small fw-bold text-muted uppercase tracking-wider">SMTP Port</label>
                            <input type="number" name="SmtpPort" class="form-control rounded-3" value="@GetVal("SmtpPort", "587")">
                        </div>
                        <div class="p-3 rounded-4 bg-light border border-light-2">
                            <div class="form-check form-switch mb-2">
                                <input type="checkbox" name="EmailNotifications" class="form-check-input mt-1" value="on" @(GetBool("EmailNotifications") ? "checked" : "")>
                                <label class="form-check-label small fw-bold">System Email Dispatch</label>
                            </div>
                            <div class="form-check form-switch">
                                <input type="checkbox" name="DailyReports" class="form-check-input mt-1" value="on" @(GetBool("DailyReports") ? "checked" : "")>
                                <label class="form-check-label small fw-bold">Auto-generate Daily EOD</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Security & User Policies -->
            <div class="col-xl-4 col-md-6">
                <div class="card border-0 shadow-sm h-100 rounded-4 config-card">
                    <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-box bg-danger-soft text-danger me-3">
                                <i class="fas fa-user-shield"></i>
                            </div>
                            <h6 class="fw-800 mb-0">Security & Access</h6>
                        </div>
                    </div>
                    <div class="card-body p-4 pt-2">
                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <label class="form-label x-small fw-bold text-muted uppercase tracking-wider">Session Limit</label>
                                <div class="input-group">
                                    <input type="number" name="SessionTimeout" class="form-control rounded-start-3" value="@GetVal("SessionTimeout", "60")">
                                    <span class="input-group-text bg-light border-0 x-small">min</span>
                                </div>
                            </div>
                            <div class="col-6">
                                <label class="form-label x-small fw-bold text-muted uppercase tracking-wider">Min Password</label>
                                <div class="input-group">
                                    <input type="number" name="PasswordMinLength" class="form-control rounded-start-3" value="@GetVal("PasswordMinLength", "8")">
                                    <span class="input-group-text bg-light border-0 x-small">chars</span>
                                </div>
                            </div>
                        </div>
                        <div class="p-3 rounded-4 bg-light mb-0">
                            <div class="row g-3">
                                <div class="col-12">
                                    <div class="form-check form-switch custom-switch-danger p-0 m-0 d-flex align-items-center justify-content-between">
                                        <label class="form-check-label small fw-bold">Enforce 2FA for Admins</label>
                                        <input type="checkbox" name="TwoFactorAuth" class="form-check-input m-0" value="on" @(GetBool("TwoFactorAuth") ? "checked" : "")>
                                    </div>
                                </div>
                                <div class="col-12 border-top border-light pt-2">
                                    <div class="form-check form-switch p-0 m-0 d-flex align-items-center justify-content-between">
                                        <label class="form-check-label small fw-bold">Strong Password (Numbers)</label>
                                        <input type="checkbox" name="RequireNumbers" class="form-check-input m-0" value="on" @(GetBool("RequireNumbers") ? "checked" : "")>
                                    </div>
                                </div>
                                <div class="col-12 border-top border-light pt-2">
                                    <div class="form-check form-switch p-0 m-0 d-flex align-items-center justify-content-between">
                                        <label class="form-check-label small fw-bold">Require Special Characters</label>
                                        <input type="checkbox" name="RequireSpecialChars" class="form-check-input m-0" value="on" @(GetBool("RequireSpecialChars") ? "checked" : "")>
                                    </div>
                                </div>
                                <div class="col-12 border-top border-light pt-2">
                                    <div class="form-check form-switch p-0 m-0 d-flex align-items-center justify-content-between">
                                        <label class="form-check-label small fw-bold">Allow Public Registration</label>
                                        <input type="checkbox" name="AllowPublicRegistration" class="form-check-input m-0" value="on" @(GetBool("AllowPublicRegistration") ? "checked" : "")>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Advanced Automation & Logs -->
            <div class="col-xl-8 col-md-12">
                <div class="card border-0 shadow-sm h-100 rounded-4 config-card">
                    <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-box bg-warning-soft text-warning me-3">
                                <i class="fas fa-robot"></i>
                            </div>
                            <h6 class="fw-800 mb-0">Automation & Advanced Controls</h6>
                        </div>
                    </div>
                    <div class="card-body p-4 pt-2">
                        <div class="row g-4">
                            <div class="col-md-7 border-end border-light">
                                <div class="p-4 rounded-4 bg-danger bg-opacity-10 border border-danger border-opacity-10 mb-4 h-100">
                                    <div class="d-flex align-items-center justify-content-between mb-3">
                                        <h6 class="mb-0 fw-bold text-danger"><i class="fas fa-tools me-2"></i>Selective Maintenance Mode</h6>
                                        <div class="form-check form-switch p-0">
                                            <input type="checkbox" name="MaintenanceMode" class="form-check-input m-0" value="on" @(GetBool("MaintenanceMode") ? "checked" : "")>
                                        </div>
                                    </div>
                                    <p class="x-small text-danger opacity-75 mb-3">Select the specific user roles to restrict from accessing the system:</p>
                                    
                                    @{
                                        var maintRoles = GetVal("MaintenanceRoles", "");
                                        var roleList = new[] { "Admin", "Manager", "Cashier", "MarketingStaff" };
                                    }
                                    <div class="d-flex flex-wrap gap-3">
                                        @foreach(var role in roleList) {
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="MaintRole_@role" id="maint_@role" value="true" @(maintRoles.Contains(role) ? "checked" : "")>
                                                <label class="form-check-label small fw-bold text-dark" for="maint_@role">@role</label>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label class="form-label x-small fw-bold text-muted uppercase tracking-wider">Log Retention Policy</label>
                                        <div class="input-group">
                                            <input type="number" name="LogRetentionDays" class="form-control rounded-start-3" value="@GetVal("LogRetentionDays", "30")">
                                            <span class="input-group-text bg-light border-0 x-small">Retention (Days)</span>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="p-3 bg-light rounded-4 border border-light">
                                            <div class="form-check form-switch mb-2 p-0 d-flex align-items-center justify-content-between">
                                                <label class="form-check-label small fw-bold">Inventory Low Stock Alerts</label>
                                                <input type="checkbox" name="LowStockAlerts" class="form-check-input m-0" value="on" @(GetBool("LowStockAlerts") ? "checked" : "")>
                                            </div>
                                            <div class="input-group mt-2">
                                                <input type="number" name="LowStockThreshold" class="form-control form-control-sm rounded-start-3" value="@GetVal("LowStockThreshold", "10")">
                                                <span class="input-group-text bg-white border x-small border-start-0">Warning Threshold</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    :root {
        --primary-soft: rgba(30, 64, 175, 0.1);
        --success-soft: rgba(21, 128, 61, 0.1);
        --danger-soft: rgba(185, 28, 28, 0.1);
        --warn-soft: rgba(180, 83, 9, 0.1);
        --info-soft: rgba(14, 116, 144, 0.1);
        --amber-soft: rgba(245, 158, 11, 0.1);
    }
    .fw-800 { font-weight: 800; }
    .fw-900 { font-weight: 900; }
    .uppercase { text-transform: uppercase; }
    .tracking-wider { letter-spacing: 0.1em; }
    .x-small { font-size: 0.72rem; }
    
    .border-left-premium {
        border-left: 5px solid var(--accent-amber);
    }
    
    .config-card {
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease;
    }
    
    .config-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px -5px rgba(0,0,0,0.1) !important;
    }

    .icon-box {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    .bg-primary-soft { background: var(--primary-soft); }
    .bg-success-soft { background: var(--success-soft); }
    .bg-danger-soft { background: var(--danger-soft); }
    .bg-warning-soft { background: var(--warn-soft); }
    .bg-info-soft { background: var(--info-soft); }

    .form-control, .form-select {
        border: 2px solid #f1f5f9;
        padding: 10px 14px;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    
    .form-control:focus, .form-select:focus {
        border-color: var(--accent-amber);
        box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.1);
    }

    .form-check-input {
        width: 2.8em !important;
        height: 1.5em !important;
        cursor: pointer;
    }

    .form-check-input:checked {
        background-color: var(--accent-amber);
        border-color: var(--accent-amber);
    }

    .bg-amber-light { background: #fffbeb; }
    .text-amber { color: #b45309; }
</style>
