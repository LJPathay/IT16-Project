@model IEnumerable<ljp_itsolutions.Models.SecurityLog>
@using ljp_itsolutions.Helpers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Security Logs";
}

<div class="container-fluid py-2">
    <!-- Filters Bar -->
    <div class="row g-3 mb-4 align-items-center">
        <div class="col-md-3">
            <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                <span class="input-group-text bg-white border-0 ps-3">
                    <i class="fas fa-search text-muted"></i>
                </span>
                <input type="text" id="logSearch" class="form-control border-0 shadow-none ps-2 py-2" placeholder="Search security events..." aria-label="logSearch">
            </div>
        </div>
        <div class="col-md-3">
            <select id="severityFilter" class="form-select shadow-sm rounded-pill border py-2" aria-label="severityFilter">
                <option value="">All Severities</option>
                <option value="Info">Info</option>
                <option value="Warning">Warning</option>
                <option value="Critical">Critical</option>
            </select>
        </div>
        <div class="col-md-4">
            <div class="d-flex align-items-center gap-2">
                <input type="date" id="dateFilterFrom" class="form-control shadow-sm rounded-pill border py-2" title="From Date" aria-label="dateFilterFrom">
                <span class="text-muted">to</span>
                <input type="date" id="dateFilterTo" class="form-control shadow-sm rounded-pill border py-2" title="To Date" aria-label="dateFilterTo">
            </div>
        </div>
        <div class="col-md-2 text-end">
            <button id="resetFilters" class="btn btn-light border rounded-pill px-4 ms-auto">
                Reset
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0" id="securityTable">
                    <thead class="bg-light bg-opacity-50">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase x-small fw-bold text-muted" style="width: 200px;">Timestamp</th>
                            <th class="py-3 text-uppercase x-small fw-bold text-muted">Operator Info</th>
                            <th class="py-3 text-uppercase x-small fw-bold text-muted">Security Event</th>
                            <th class="py-3 text-uppercase x-small fw-bold text-muted">IP / Agent</th>
                            <th class="pe-4 py-3 text-end text-uppercase x-small fw-bold text-muted" style="width: 120px;">Severity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            var isGuest = log.User == null;
                            <tr class="log-row" data-severity="@log.Severity" data-timestamp="@log.Timestamp.ToString("yyyy-MM-dd")">
                                <td class="ps-4">
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-dark small">@log.Timestamp.ToString("MMM dd, yyyy")</span>
                                        <span class="text-muted x-small">@log.Timestamp.ToString("HH:mm:ss")</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                         <div class="avatar-xs rounded-circle bg-light d-flex align-items-center justify-content-center border" style="width: 32px; height: 32px; font-size: 0.7rem; overflow: hidden;">
                                             @if (log.User != null && !string.IsNullOrEmpty(log.User.ProfilePictureUrl)) {
                                                 <img src="@log.User.ProfilePictureUrl" alt="@(log.User.FullName ?? "User")" class="w-100 h-100 object-fit-cover shadow-sm">
                                             } else if (isGuest) {
                                                 <i class="fas fa-user-secret opacity-50 text-warning"></i>
                                             } else {
                                                 <i class="fas fa-user-shield opacity-50 text-primary"></i>
                                             }
                                         </div>
                                         <div>
                                             <p class="mb-0 small fw-bold text-dark">@(log.User?.FullName ?? (log.User != null ? SecurityHelper.MaskUsername(log.User.Username) : "System / Anonymous"))</p>
                                             <p class="text-muted x-small mb-0">@(log.User?.Role ?? "Internal")</p>
                                         </div>
                                     </div>
                                 </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="small fw-bold text-dark action-text">@log.EventType</span>
                                        <span class="text-muted x-small description-text" style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@log.Description">@log.Description</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="small text-dark font-monospace">@(string.IsNullOrEmpty(log.IpAddress) ? "::1" : log.IpAddress)</span>
                                    </div>
                                </td>
                                <td class="pe-4 text-end">
                                    @if (log.Severity == "Critical") {
                                        <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger border-opacity-10 px-3 x-small">CRITICAL</span>
                                    } else if (log.Severity == "Warning") {
                                        <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning border border-warning border-opacity-10 px-3 x-small">WARNING</span>
                                    } else {
                                        <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success border-opacity-10 px-3 x-small">INFO</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center py-5" id="emptyState">
                    <i class="fas fa-file-shield fa-4x text-light mb-3"></i>
                    <p class="text-muted">No security events recorded yet.</p>
                </div>
            }
        </div>
        <partial name="_Pagination" model='("securityTable", "startRange", "endRange", "totalItems", "pagination")' />
    </div>
</div>

@section Scripts {
    <partial name="_PaginationScripts" model='("securityTable", "log-row", "startRange", "endRange", "totalItems", "pagination", 15)' />
    <script>
        $(document).ready(function() {
            function filterLogs() {
                var searchTerm = $('#logSearch').val().toLowerCase();
                var severityFilter = $('#severityFilter').val();
                var dateFrom = $('#dateFilterFrom').val();
                var dateTo = $('#dateFilterTo').val();
                var allRows = Array.from(document.querySelectorAll('.log-row'));

                const filtered = allRows.filter(function(row) {
                    var $row = $(row);
                    var actionText = $row.find('.action-text').text().toLowerCase();
                    var descText = $row.find('.description-text').text().toLowerCase();
                    var userName = $row.find('.fw-bold').text().toLowerCase();
                    var severity = $row.data('severity');
                    var logDate = $row.data('timestamp');

                    var matchesSearch = actionText.includes(searchTerm) || descText.includes(searchTerm) || userName.includes(searchTerm);
                    var matchesSeverity = severityFilter === "" || severity === severityFilter;
                    
                    var matchesDate = true;
                    if (dateFrom && logDate < dateFrom) matchesDate = false;
                    if (dateTo && logDate > dateTo) matchesDate = false;

                    return matchesSearch && matchesSeverity && matchesDate;
                });

                window.paginationControl.update(filtered);

                if (filtered.length === 0) {
                    if ($('#noResultsRow').length === 0) {
                        $('#securityTable tbody').append('<tr id="noResultsRow"><td colspan="5" class="text-center py-5 text-muted"><i class="fas fa-search-minus fa-3x mb-3 opacity-25"></i><p>No security records found matching filters.</p></td></tr>');
                    }
                } else {
                    $('#noResultsRow').remove();
                }
            }

            $('#logSearch').on('keyup', filterLogs);
            $('#severityFilter, #dateFilterFrom, #dateFilterTo').on('change', filterLogs);
            
            $('#resetFilters').click(function() {
                $('#logSearch').val('');
                $('#severityFilter').val('');
                $('#dateFilterFrom').val('');
                $('#dateFilterTo').val('');
                filterLogs();
            });
        });
    </script>
}

<style>
    .x-small { font-size: 0.75rem; }
    .action-text { display: block; margin-bottom: 2px; }
</style>
