@model List<ljp_itsolutions.Models.ProductSalesSummary>
@{
    ViewData["Title"] = "Business Intelligence";
}

<div class="container-fluid py-4">
<div class="container-fluid py-4">
    <div class="d-flex justify-content-end mb-4 gap-2">
        <div class="d-flex gap-2">
            <input type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-01")" />
            <span class="align-self-center">to</span>
            <input type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            <button class="btn btn-primary rounded-pill px-4">Filter</button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-7">
            <div class="card border shadow-sm rounded-3 overflow-hidden">
                <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">Sales Volume</h5>
                    <span class="text-muted small">Unit Sales History</span>
                </div>
                <div class="card-body">
                    <div style="height: 350px;">
                        <canvas id="salesChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card border shadow-sm rounded-3 overflow-hidden">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="fw-bold mb-0 text-slate-700">Operational Revenue Insights</h5>
                </div>
                <div class="card-body">
                    <div style="height: 350px;">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border shadow-sm rounded-3 overflow-hidden mb-4">
        <div class="p-3 bg-light border-bottom d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0">Top Performing Products</h5>
            <div class="d-flex gap-2">
                <button onclick="emailReport()" id="emailReportBtn" class="btn btn-sm btn-outline-success rounded-pill px-4">
                    <i class="fas fa-envelope me-2"></i>Email Report
                </button>
                <button onclick="exportCSV()" class="btn btn-sm btn-outline-primary rounded-pill px-4">
                    <i class="fas fa-file-export me-2"></i>Export CSV
                </button>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Product Name</th>
                        <th>Total Sold</th>
                        <th>Revenue Generated</th>
                        <th class="text-end pe-4">Sales Progress</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark">@item.ProductName</span>
                            </td>
                            <td><span class="badge bg-light text-dark rounded-pill">@item.TotalSold units</span></td>
                            <td class="fw-bold text-success">₱@item.Revenue.ToString("N2")</td>
                            <td class="text-end pe-4">
                                @{
                                    var progress = Math.Min(100, (int)(item.TotalSold * 1.5)); // Simulated progress
                                }
                                <div class="d-flex align-items-center justify-content-end">
                                    <div class="progress rounded-pill me-2" style="height: 6px; width: 100px;">
                                        <div class="progress-bar bg-primary" style="width: @progress%"></div>
                                    </div>
                                    <span class="small text-muted">@progress%</span>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4">
                                <div class="empty-state p-5">
                                    <i class="fas fa-chart-pie empty-state-icon fa-2x"></i>
                                    <p class="text-muted">No sales data found for the selected period.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>
    <script>
        Chart.register(ChartDataLabels);

        document.addEventListener("DOMContentLoaded", function () {
            const chartOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { 
                            boxWidth: 12, 
                            usePointStyle: true, 
                            pointStyle: 'circle', 
                            font: { size: 11, weight: 'bold' },
                            generateLabels: function(chart) {
                                const data = chart.data;
                                if (data.labels.length && data.datasets.length) {
                                    const dataset = data.datasets[0];
                                    const total = dataset.data.reduce((a, b) => a + b, 0);
                                    return data.labels.map((label, i) => {
                                        const value = dataset.data[i];
                                        const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                        const text = chart.config.type === 'doughnut' ? `${label} (${percentage}%)` : label;
                                        return {
                                            text: text,
                                            fillStyle: Array.isArray(dataset.backgroundColor) ? dataset.backgroundColor[i] : dataset.backgroundColor,
                                            strokeStyle: Array.isArray(dataset.backgroundColor) ? dataset.backgroundColor[i] : dataset.backgroundColor,
                                            lineWidth: 0,
                                            index: i
                                        };
                                    });
                                }
                                return [];
                            }
                        }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(255, 255, 255, 0.9)',
                        titleColor: '#1e293b',
                        bodyColor: '#475569',
                        borderColor: '#e2e8f0',
                        borderWidth: 1,
                        padding: 12,
                        boxPadding: 6,
                        usePointStyle: true,
                        callbacks: {
                            label: function(context) {
                                let label = context.label || '';
                                if (label) label += ': ';
                                if (context.parsed !== null) {
                                    if (context.dataset.label === 'Units Sold') {
                                        label += context.parsed + ' units';
                                    } else {
                                        const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                        const percentage = ((context.raw / total) * 100).toFixed(1);
                                        label += '₱' + context.parsed.toLocaleString() + ' (' + percentage + '%)';
                                    }
                                }
                                return label;
                            }
                        }
                    },
                    datalabels: {
                        display: true,
                        color: (context) => context.chart.config.type === 'doughnut' ? '#fff' : '#475569',
                        anchor: (context) => context.chart.config.type === 'doughnut' ? 'center' : 'end',
                        align: (context) => context.chart.config.type === 'doughnut' ? 'center' : 'top',
                        font: { weight: 'bold', size: 10 },
                        formatter: (value, context) => {
                            if (context.chart.config.type === 'doughnut') {
                                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                if (total === 0) return '';
                                const percentage = (value / total * 100).toFixed(1);
                                if (percentage < 3) return ''; // Hide if too small
                                return percentage + '%';
                            }
                            return value;
                        }
                    }
                }
            };

            // Sales Volume Chart
            const salesCtx = document.getElementById('salesChart').getContext('2d');
            new Chart(salesCtx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
                    datasets: [{
                        label: 'Units Sold',
                        data: @Html.Raw(Json.Serialize(ViewBag.ChartData)),
                        backgroundColor: '#3b82f6',
                        borderRadius: 6,
                        hoverBackgroundColor: '#2563eb'
                    }]
                },
                options: {
                    ...chartOptions,
                    scales: {
                        y: { 
                            beginAtZero: true,
                            grid: { color: 'rgba(0,0,0,0.03)' },
                            ticks: { font: { size: 11 } }
                        },
                        x: { grid: { display: false }, ticks: { font: { size: 11 } } }
                    }
                }
            });

            // Revenue Chart
            const revenueCtx = document.getElementById('revenueChart').getContext('2d');
            new Chart(revenueCtx, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(ViewBag.RevenueData)),
                        backgroundColor: [
                            '#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899'
                        ],
                        borderWidth: 2,
                        borderColor: '#fff',
                        cutout: '70%',
                        hoverOffset: 15
                    }]
                },
                options: { ...chartOptions }
            });
        });

        async function emailReport() {
            const btn = document.getElementById('emailReportBtn');
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Sending...';
            btn.disabled = true;

            const startDate = document.querySelector('input[type="date"]:first-of-type').value;
            const endDate = document.querySelector('input[type="date"]:last-of-type').value;

            try {
                const response = await fetch('@Url.Action("EmailSalesReport", "Manager")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: `startDate=${startDate}&endDate=${endDate}`
                });

                const data = await response.json();
                if (data.success) {
                    btn.innerHTML = '<i class="fas fa-check me-2"></i>Sent!';
                    btn.classList.replace('btn-outline-success', 'btn-success');
                    setTimeout(() => {
                        btn.innerHTML = originalHtml;
                        btn.classList.replace('btn-success', 'btn-outline-success');
                        btn.disabled = false;
                    }, 3000);
                } else {
                    alert(data.message);
                    btn.innerHTML = originalHtml;
                    btn.disabled = false;
                }
            } catch (err) {
                alert('Connection error logic failed.');
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
        }

        function exportCSV() {
            const startDate = document.querySelector('input[type="date"]:first-of-type').value;
            const endDate = document.querySelector('input[type="date"]:last-of-type').value;
            
            window.location.href = `@Url.Action("ExportSalesCSV", "Manager")?startDate=${startDate}&endDate=${endDate}`;
        }
    </script>
    @Html.AntiForgeryToken()
}


