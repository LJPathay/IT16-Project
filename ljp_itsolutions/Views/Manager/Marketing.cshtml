@model ljp_itsolutions.Services.MarketingDashboardData
@{
    ViewData["Title"] = "Marketing Performance";
    var activePromos = (int)(ViewBag.ActivePromos ?? 0);
    var totalPromoUses = (int)(ViewBag.TotalPromoUses ?? 0);
    var totalPromoRevenue = (decimal)(ViewBag.TotalPromoRevenue ?? 0m);
    var avgDiscount = (decimal)(ViewBag.AvgDiscount ?? 0m);
}

<div class="container-fluid py-4">

    <!-- Page Header -->
    <div class="d-flex justify-content-end align-items-center mb-4">
        <button onclick="location.href='@Url.Action("ExportTacticalROI", "Marketing")'" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold btn-sm">
            <i class="fas fa-file-export me-2"></i>Export Data
        </button>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="kpi-card-premium brand-primary transition-hover">
                <div class="kpi-content">
                    <p class="kpi-title">Active Campaigns</p>
                    <span class="kpi-main-val">@activePromos</span>
                    <div class="kpi-trend text-muted"><i class="fas fa-bullhorn me-1"></i>Live Now</div>
                </div>
                <div class="kpi-icon-box">
                    <i class="fas fa-bullhorn"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card-premium brand-success transition-hover">
                <div class="kpi-content">
                    <p class="kpi-title">Promo Redemptions</p>
                    <span class="kpi-main-val">@totalPromoUses</span>
                    <div class="kpi-trend text-muted"><i class="fas fa-check-circle me-1"></i>Total Uses</div>
                </div>
                <div class="kpi-icon-box">
                    <i class="fas fa-ticket-alt"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card-premium brand-danger transition-hover">
                <div class="kpi-content">
                    <p class="kpi-title">Avg. Discount</p>
                    <span class="kpi-main-val" style="font-size:1.4rem;">₱@avgDiscount.ToString("N2")</span>
                    <div class="kpi-trend text-muted"><i class="fas fa-tag me-1"></i>Per Order</div>
                </div>
                <div class="kpi-icon-box">
                    <i class="fas fa-tag"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card-premium brand-indigo transition-hover">
                <div class="kpi-content">
                    <p class="kpi-title">Promo Revenue</p>
                    <span class="kpi-main-val" style="font-size:1.25rem;">₱@totalPromoRevenue.ToString("N0")</span>
                    <div class="kpi-trend text-muted">Campaign Driven</div>
                </div>
                <div class="kpi-icon-box">
                    <i class="fas fa-chart-line"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row 1 -->
    <div class="row g-4 mb-4">
        <!-- Engagement / Conversion Trend -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-2">
                    <h6 class="fw-bold mb-0 text-dark">Engagement & Conversion Trends</h6>
                    <p class="text-muted xx-small mb-0">7-day aggregate conversion volume</p>
                </div>
                <div class="card-body p-4 pt-2">
                    <div style="height: 280px;">
                        <canvas id="performanceChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- New vs Returning Patrons -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-2">
                    <h6 class="fw-bold mb-0 text-dark">Patron Acquisition Matrix</h6>
                    <p class="text-muted xx-small mb-0">New vs. returning loyalty share</p>
                </div>
                <div class="card-body p-4 pt-2">
                    <div style="height: 250px;">
                        <canvas id="patronChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row 2 -->
    <div class="row g-4 mb-4">
        <!-- VIP Loyalty -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-2">
                    <h6 class="fw-bold mb-0 text-dark">VIP Loyalty Equity</h6>
                    <p class="text-muted xx-small mb-0">Top patrons by engagement points</p>
                </div>
                <div class="card-body p-4 pt-2">
                    <div style="height: 280px;">
                        <canvas id="vipEquityChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tier Saturation -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-2">
                    <h6 class="fw-bold mb-0 text-dark">Loyalty Tier Distribution</h6>
                    <p class="text-muted xx-small mb-0">Cross-demographic loyalty tier achievement</p>
                </div>
                <div class="card-body p-4 pt-2">
                    <div style="height: 280px;">
                        <canvas id="tierSaturationChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js" integrity="sha384-52b3468745678901234567890123456789012345678901234567890123456789" crossorigin="anonymous"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const primaryColor = '#4f46e5';

            // Engagement / Conversion Trend
            const perfLabels = @Html.Raw(Json.Serialize(Model?.PerformanceLabels ?? new List<string>()));
            const perfData   = @Html.Raw(Json.Serialize(Model?.PerformanceData ?? new List<int>()));

            new Chart(document.getElementById('performanceChart').getContext('2d'), {
                type: 'line',
                data: {
                    labels: perfLabels,
                    datasets: [{
                        label: 'Conversions',
                        data: perfData,
                        borderColor: '#4f46e5',
                        backgroundColor: 'rgba(79,70,229,0.06)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: '#4f46e5'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } } }
                }
            });

            // Patron Acquisition Matrix
            new Chart(document.getElementById('patronChart').getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: ['New Patrons', 'Returning'],
                    datasets: [{
                        data: [@(Model?.NewPatronsCount ?? 0), @(Model?.ReturningPatronsCount ?? 0)],
                        backgroundColor: ['#3b82f6', '#6366f1'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '72%',
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20, font: { size: 11 } } }
                    }
                }
            });

            // VIP Equity
            const vipLabels = @Html.Raw(Json.Serialize(Model?.VIPPerformance?.Select(v => v.FullName).ToList() ?? new List<string>()));
            const vipData   = @Html.Raw(Json.Serialize(Model?.VIPPerformance?.Select(v => v.Points).ToList() ?? new List<int>()));

            new Chart(document.getElementById('vipEquityChart').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: vipLabels,
                    datasets: [{
                        data: vipData,
                        backgroundColor: '#4f46e5',
                        borderRadius: 8
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { x: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } } }
                }
            });

            // Tier Saturation
            const tierLabels = @Html.Raw(Json.Serialize(Model?.TierLabels ?? new List<string>()));
            const tierData   = @Html.Raw(Json.Serialize(Model?.TierData ?? new List<int>()));

            new Chart(document.getElementById('tierSaturationChart').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: tierLabels,
                    datasets: [{
                        label: 'Patrons',
                        data: tierData,
                        backgroundColor: ['#e67e22', '#6366f1', '#94a3b8', '#e2e8f0'],
                        borderRadius: 12
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } } }
                }
            });
        });
    </script>
}

<style>
    .x-small  { font-size: 0.75rem; }
    .xx-small { font-size: 0.65rem; }
</style>
