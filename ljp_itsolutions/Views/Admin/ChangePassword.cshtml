<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden ux-animate-fade-in">
                <div class="card-header bg-dark text-white p-4 border-0">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-amber p-2 rounded-circle shadow-sm" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-key text-dark"></i>
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold">Update Password</h4>
                            <p class="mb-0 x-small opacity-75">Target Account: @Model.UserName</p>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4 p-lg-5 bg-white">
                    <form method="post" asp-action="ChangePassword" id="adminChangeForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        
                        <div class="mb-4">
                            <label class="form-label x-small fw-bold text-muted text-uppercase mb-2">New Security Access Code</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3"><i class="fas fa-lock x-small"></i></span>
                                <input type="password" name="newPassword" id="admin-new-password" class="form-control border-start-0 rounded-end-3 py-2" required placeholder="Enter new password" / aria-label="newPassword">
                            </div>
                            <partial name="_PasswordRequirements" model='("admin-new-password", "admin-submit-btn", Model.UserName ?? "", true, "")' />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" id="admin-submit-btn" class="btn btn-dark btn-lg rounded-pill fw-bold py-2 shadow-sm" disabled>
                                Confirm Access Update
                            </button>
                            <a href="/Admin/Dashboard" class="btn btn-link text-muted x-small text-decoration-none">Return to Dashboard</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-amber { background-color: #f59e0b; }
    .x-small { font-size: 0.75rem; }
    .ux-animate-fade-in { animation: fadeIn 0.5s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>
