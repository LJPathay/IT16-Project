@model IEnumerable<ljp_itsolutions.Models.SecurityLog>
@using ljp_itsolutions.Helpers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Security Activity Monitoring";
}

<div class="container-fluid py-4">
    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center p-3">
                <div class="display-6 fw-bold text-primary">@Model.Count()</div>
                <div class="text-muted x-small text-uppercase fw-bold">Recent Events</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center p-3">
                <div class="display-6 fw-bold text-danger">@Model.Count(l => l.Severity == "Critical")</div>
                <div class="text-muted x-small text-uppercase fw-bold">Critical Alerts</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center p-3">
                <div class="display-6 fw-bold text-warning">@Model.Count(l => l.EventType == "LoginFailure")</div>
                <div class="text-muted x-small text-uppercase fw-bold">Failed Logins</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center p-3">
                <div class="display-6 fw-bold text-info">@Model.Count(l => l.EventType == "MfaSuccess")</div>
                <div class="text-muted x-small text-uppercase fw-bold">MFA Verifications</div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="row g-2">
                <div class="col-md-6">
                    <input type="text" id="secSearch" class="form-control border-light shadow-none rounded-pill px-4" placeholder="Search by description or event type..." aria-label="secSearch">
                </div>
                <div class="col-md-3">
                    <select id="sevFilter" class="form-select border-light shadow-none rounded-pill" aria-label="sevFilter">
                        <option value="">All Severities</option>
                        <option value="Info">Info</option>
                        <option value="Warning">Warning</option>
                        <option value="Critical">Critical</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button id="clearBtn" class="btn btn-outline-secondary w-100 rounded-pill">Clear Filters</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Logs Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0" id="secTable">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Severity</th>
                        <th>Event</th>
                        <th>User</th>
                        <th>Details</th>
                        <th>Timestamp</th>
                        <th class="pe-4 text-end">Origin IP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        var sevBadge = log.Severity switch {
                            "Critical" => "bg-danger",
                            "Warning" => "bg-warning text-dark",
                            _ => "bg-info"
                        };
                        <tr class="sec-row" data-sev="@log.Severity">
                            <td class="ps-4">
                                <span class="badge rounded-pill @sevBadge px-3">@log.Severity</span>
                            </td>
                            <td><span class="fw-bold small">@log.EventType</span></td>
                            <td><span class="text-dark small">@(log.User?.Username ?? "N/A")</span></td>
                            <td><div class="x-small text-muted desc-cell" style="max-width:300px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@log.Description</div></td>
                            <td><span class="text-muted x-small">@log.Timestamp.ToString("MMM dd HH:mm:ss")</span></td>
                            <td class="pe-4 text-end font-monospace x-small text-secondary">@SecurityHelper.MaskIpAddress(log.IpAddress ?? string.Empty)</td>
                        </tr>
                    }
                </tbody>
        <partial name="_Pagination" model='("secTable", "startRange", "endRange", "totalItems", "pagination")' />
    </div>
</div>

@section Scripts {
    <script>
        <partial name="_PaginationScripts" model='("secTable", "sec-row", "startRange", "endRange", "totalItems", "pagination", 10)' />

        $(document).ready(function() {
            function filter() {
                var s = $('#secSearch').val().toLowerCase();
                var v = $('#sevFilter').val();
                const allRows = Array.from(document.querySelectorAll('.sec-row'));
                
                const filtered = allRows.filter(function(row) {
                    var t = row.textContent.toLowerCase();
                    var sv = row.getAttribute('data-sev');
                    return t.includes(s) && (v === "" || sv === v);
                });
                
                window.paginationControl.update(filtered);
            }
            $('#secSearch').keyup(filter);
            $('#sevFilter').change(filter);
            $('#clearBtn').click(function() {
                $('#secSearch').val(''); $('#sevFilter').val(''); $('.sec-row').show();
            });
        });
    </script>
}

<style>
    .x-small { font-size: 0.75rem; }
</style>
