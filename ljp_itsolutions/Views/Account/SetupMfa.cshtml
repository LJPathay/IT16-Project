@{
    ViewData["Title"] = "Setup Two-Factor Authentication";
    var qrData = ViewBag.QrCodeData as string;
    var secret = ViewBag.Secret as string;
    // Using Google Charts API for quick, dependency-free QR code generation
    var qrUrl = $"https://chart.googleapis.com/chart?chs=200x200&chld=M|0&cht=qr&chl={Uri.EscapeDataString(qrData)}";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-dark text-white text-center py-4">
                    <h4 class="mb-0"><i class="fas fa-key mr-2"></i> Security Setup</h4>
                </div>
                <div class="card-body p-5">
                    <h5 class="font-weight-bold mb-4">Set up Authenticator App</h5>
                    
                    <ol class="text-muted mb-4 pl-3">
                        <li>Download an authenticator app (e.g., Google Authenticator, Authy, Microsoft Authenticator).</li>
                        <li>Scan the QR code below or enter the key manually.</li>
                        <li>Enter the 6-digit code generated by the app to verify.</li>
                    </ol>

                    <div class="text-center mb-4">
                        <div class="p-3 bg-white d-inline-block rounded shadow-sm" style="border: 1px solid #edf2f7;">
                            <img src="@qrUrl" alt="QR Code" style="width: 200px; height: 200px;" />
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="text-xs font-weight-bold text-uppercase text-secondary">Manual Entry Key</label>
                        <div class="input-group">
                            <input type="text" class="form-control bg-light font-weight-bold" value="@secret" readonly 
                                   style="font-family: monospace; letter-spacing: 1px; border-radius: 8px 0 0 8px;" />
                            <div class="input-group-append">
                                <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('@secret')">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <form asp-action="EnableMfa" method="post">
                        <input type="hidden" name="secret" value="@secret" />
                        <div class="form-group">
                            <label class="font-weight-600">Enter Verification Code</label>
                            <input name="code" class="form-control form-control-lg text-center" placeholder="000 000" maxlength="6" required 
                                   style="border-radius: 10px; font-weight: bold; letter-spacing: 2px;" />
                        </div>
                        <button type="submit" class="btn btn-success btn-block btn-lg shadow-sm mt-3 py-3" style="border-radius: 10px; font-weight: 600;">
                            Confirm & Enable
                        </button>
                    </form>
                </div>
                <div class="card-footer bg-light text-center py-3">
                    <a asp-action="Profile" class="text-secondary small font-weight-600">Nevermind, take me back</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function copyToClipboard(text) {
        navigator.clipboard.writeText(text).then(() => {
            alert('Key copied to clipboard!');
        });
    }
</script>
