@{
    ViewData["Title"] = "Setup Two-Factor Authentication";
    var qrData = ViewBag.QrCodeData as string;
    var secret = ViewBag.Secret as string;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white text-center py-4 border-0">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-shield-alt me-2"></i> Security Infrastructure</h4>
                </div>
                <div class="card-body p-5">
                    <h5 class="fw-bold mb-3 text-dark">Enable Authenticator App</h5>
                    
                    <div class="alert alert-light border-0 small mb-4 py-3 px-4 rounded-3" style="background-color: #f8f9fa;">
                        <ol class="mb-0 ps-3">
                            <li class="mb-1">Install an authenticator app (Google Authenticator, Authy, etc).</li>
                            <li class="mb-1">Scan the secure matrix below or type the key manually.</li>
                            <li>Enter the resulting 6-digit verification code.</li>
                        </ol>
                    </div>

                    <div class="text-center mb-4">
                        <div class="p-3 d-inline-block rounded-4 shadow-sm bg-white border">
                            <canvas id="qr-canvas"></canvas>
                        </div>
                        <p class="text-muted xx-small mt-2"><i class="fas fa-lock me-1"></i> Locally generated secure matrix</p>
                    </div>

                    <div class="form-group mb-4">
                        <label class="text-xs font-weight-bold text-uppercase text-secondary">Manual Entry Key</label>
                        <div class="input-group">
                            <input type="text" class="form-control bg-light font-weight-bold" value="@secret" readonly 
                                   style="font-family: monospace; letter-spacing: 1px; border-radius: 8px 0 0 8px;" />
                            <div class="input-group-append">
                                <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('@secret')">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <form asp-action="EnableMfa" method="post">
                        <input type="hidden" name="secret" value="@secret" />
                        <div class="form-group">
                            <label class="font-weight-600">Enter Verification Code</label>
                            <input name="code" class="form-control form-control-lg text-center" placeholder="000 000" maxlength="6" required 
                                   style="border-radius: 10px; font-weight: bold; letter-spacing: 2px;" />
                        </div>
                        <button type="submit" class="btn btn-success btn-block btn-lg shadow-sm mt-3 py-3" style="border-radius: 10px; font-weight: 600;">
                            Confirm & Enable
                        </button>
                    </form>
                </div>
                <div class="card-footer bg-light text-center py-3">
                    <a asp-action="Profile" class="text-secondary small font-weight-600">Nevermind, take me back</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrious/4.0.2/qrious.min.js" integrity="sha384-Dr98ddmUw2QkdCarNQ+OL7xLty7cSxgR0T7v1tq4UErS/qLV0132sBYTolRAFuOV" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script>
    (function() {
        var qr = new QRious({
            element: document.getElementById('qr-canvas'),
            value: '@Html.Raw(qrData)',
            size: 200,
            level: 'H'
        });
    })();

    function copyToClipboard(text) {
        navigator.clipboard.writeText(text).then(() => {
            const btn = event.currentTarget;
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check"></i>';
            btn.classList.replace('btn-outline-secondary', 'btn-success');
            setTimeout(() => {
                btn.innerHTML = originalHtml;
                btn.classList.replace('btn-success', 'btn-outline-secondary');
            }, 2000);
        });
    }
</script>
