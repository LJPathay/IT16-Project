@{
    ViewData["Title"] = "Two-Factor Verification";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h4 class="mb-0"><i class="fas fa-shield-alt mr-2"></i> Identity Verification</h4>
                </div>
                <div class="card-body p-5">
                    <p class="text-muted text-center mb-4">
                        Please enter the 6-digit code from your authenticator app to complete your sign-in.
                    </p>

                    <form asp-action="VerifyMfa" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        
                        <div class="form-group text-center">
                            <label for="code" class="sr-only">Verification Code</label>
                            <input name="code" id="code" class="form-control form-control-lg text-center letter-spacing-lg" 
                                   placeholder="000 000" maxlength="6" autofocus required
                                   style="font-size: 2rem; font-weight: 700; letter-spacing: 0.5rem; border: 2px solid #e2e8f0; border-radius: 12px;" />
                        </div>

                        <button type="submit" class="btn btn-primary btn-block btn-lg shadow-sm mt-4 py-3" style="border-radius: 12px; font-weight: 600;">
                            Verify & Sign In
                        </button>
                    </form>
                </div>
                <div class="card-footer bg-light text-center py-3">
                    <a asp-action="Login" class="text-secondary small font-weight-600">Cancel and go back</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .letter-spacing-lg {
        letter-spacing: 5px !important;
    }
    .form-control:focus {
        border-color: #4e73df !important;
        box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.25) !important;
    }
</style>
