@{
    ViewData["Title"] = "Security Verification";
    Layout = "_GuestLayout";
}

<div class="login-container">
    <div class="cafe-panel">
        <div class="cafe-logo">
            <img src="@(Url.Content("~/images/logo.png"))" alt="Coffee Shop ERP" />
        </div>
        <div class="cafe-tagline">Secure Access Control & Identity Verification</div>
    </div>

    <div class="form-panel">
        <div class="form-wrapper">
            <div class="mobile-logo">
                <img src="@(Url.Content("~/images/logo.png"))" alt="Coffee Shop ERP" />
            </div>

            <div class="login-card p-4 p-md-5">
                <div class="login-header text-center mb-4">
                    <div class="mb-3 d-inline-flex align-items-center justify-content-center bg-amber-soft rounded-circle shadow-sm" style="width: 70px; height: 70px;">
                        <i class="fas fa-shield-halved text-amber fa-2x"></i>
                    </div>
                    <h2 class="h3 font-weight-bold">Two-Factor Authentication</h2>
                    <p class="text-muted">For your security, please enter the 6-digit code from your authenticator app.</p>
                </div>

                <form asp-action="VerifyMfa" method="post" class="mt-4">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4 text-center p-2 rounded bg-light border-0"></div>
                    
                    <div class="form-group mb-4 px-2">
                        <label for="code" class="form-label d-block text-center fw-bold mb-3">Verification Code</label>
                        <div class="d-flex justify-content-center">
                            <input name="code" id="code" class="form-control-custom text-center letter-spacing-lg" 
                                   placeholder="000000" maxlength="6" autofocus required
                                   style="font-size: 2.25rem !important; font-family: 'Outfit', sans-serif; font-weight: 800; padding-left: 1rem !important; min-height: 85px;" / aria-label="code">
                        </div>
                    </div>

                    <div class="form-check mb-4 mt-2 d-flex justify-content-center">
                        <input class="form-check-input me-2" type="checkbox" name="rememberDevice" id="rememberDevice" value="true" aria-label="rememberDevice">
                        <label class="form-check-label text-muted small cursor-pointer" for="rememberDevice">
                            Trust this device for 30 days
                        </label>
                    </div>

                    <button type="submit" class="btn-signin py-3 shadow-lg mt-2">
                        <i class="fas fa-check-circle me-2"></i> Verify & Finalize Sign In
                    </button>
                    
                    <div class="text-center mt-4">
                        <a asp-action="Login" class="forgot-link text-muted small">
                            <i class="fas fa-arrow-left me-1"></i> Cancel and go back
                        </a>
                    </div>
                </form>
            </div>

            <p class="footer-text mt-5">© 2026 LJP IT SOLUTIONS Security Infrastructure</p>
        </div>
    </div>
</div>

<style>
    .letter-spacing-lg {
        letter-spacing: 0.6rem !important;
    }
    .bg-amber-soft {
        background-color: rgba(217, 119, 6, 0.1);
    }
    .text-amber {
        color: #d97706;
    }
    .form-control-custom {
        border: 2px solid #e5e7eb;
        transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    .form-control-custom:focus {
        border-color: #d97706 !important;
        box-shadow: 0 0 0 4px rgba(217, 119, 6, 0.15) !important;
        transform: translateY(-2px);
    }
</style>
