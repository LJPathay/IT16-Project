@model IEnumerable<ljp_itsolutions.Models.Notification>
@{
    ViewData["Title"] = "All Notifications";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="fw-bold mb-0 text-dark">Notification Center</h4>
                        <p class="text-muted small mb-0">Manage all your system alerts and activities</p>
                    </div>
                    @if (Model.Any(n => !n.IsRead))
                    {
                        <button onclick="markAllNotificationsAsRead()" class="btn btn-outline-primary rounded-pill px-4 fw-bold small">
                            <i class="fas fa-check-double me-2"></i>Mark All as Read
                        </button>
                    }
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 border-0 small text-muted text-uppercase fw-bold py-3" style="width: 60px;">Type</th>
                                    <th class="border-0 small text-muted text-uppercase fw-bold py-3">Details</th>
                                    <th class="border-0 small text-muted text-uppercase fw-bold py-3" style="width: 150px;">Date & Time</th>
                                    <th class="border-0 small text-muted text-uppercase fw-bold py-3 text-end pe-4" style="width: 150px;">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5">
                                            <div class="py-4">
                                                <i class="far fa-bell-slash fa-3x text-muted opacity-25 mb-3"></i>
                                                <h5 class="text-muted">No notifications found</h5>
                                                <p class="text-muted small">You're all caught up!</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var notification in Model)
                                    {
                                        <tr class="@(notification.IsRead ? "opacity-75" : "bg-primary bg-opacity-10 fw-bold")">
                                            <td class="ps-4 py-4">
                                                <div class="rounded-circle bg-@notification.Type bg-opacity-10 text-@notification.Type d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                    <i class="@notification.IconClass"></i>
                                                </div>
                                            </td>
                                            <td class="py-4">
                                                <div class="d-flex flex-column">
                                                    <span class="text-dark mb-1">@notification.Title</span>
                                                    <span class="text-muted x-small">@notification.Message</span>
                                                </div>
                                            </td>
                                            <td class="py-4">
                                                <span class="small text-muted">@notification.CreatedAt.ToString("MMM dd, yyyy")</span>
                                                <br />
                                                <span class="x-small text-muted opacity-75">@notification.CreatedAt.ToString("hh:mm tt")</span>
                                            </td>
                                            <td class="pe-4 py-4 text-end">
                                                <div class="d-flex justify-content-end gap-2">
                                                    @if (!string.IsNullOrEmpty(notification.TargetUrl))
                                                    {
                                                        <a href="@notification.TargetUrl" class="btn btn-sm btn-light rounded-pill px-3 fw-bold x-small" onclick="handleNotificationAction(@notification.NotificationID, '@notification.TargetUrl')" role="button" tabindex="0" onkeypress="if(event.key === 'Enter') this.click()">
                                                            View Scope
                                                        </a>
                                                    }
                                                    @if (!notification.IsRead)
                                                    {
                                                        <button onclick="markNotificationAsRead(@notification.NotificationID)" class="btn btn-sm btn-primary rounded-pill px-3 fw-bold x-small">
                                                            Clear
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function markAllNotificationsAsRead() {
            $.post('/Account/MarkAllRead', function() {
                location.reload();
            });
        }

        function markNotificationAsRead(id) {
            $.post('/Account/MarkAsRead', { id: id }, function() {
                location.reload();
            });
        }

        function handleNotificationAction(id, url) {
            $.post('/Account/MarkAsRead', { id: id }, function() {
                window.location.href = url;
            });
        }
    </script>
}

<style>
    .x-small { font-size: 0.75rem; }
    .tracking-tight { letter-spacing: -0.025em; }
    .bg-opacity-10 { --bs-bg-opacity: 0.1; }
</style>
