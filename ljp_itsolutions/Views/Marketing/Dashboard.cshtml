@model ljp_itsolutions.Services.MarketingDashboardData
@{
    ViewData["Title"] = "Marketing Dashboard";
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-3">
    <!-- TOP KPI SECTION: STRATEGIC REVENUE FOCUS -->
    <div class="row g-3 mb-4">
        <!-- Campaign Revenue -->
        <div class="col-md-3">
            <div class="kpi-card-premium brand-primary">
                <div class="kpi-content">
                    <p class="kpi-title">Campaign Revenue</p>
                    <span class="kpi-main-val">₱@Model.CampaignRevenue.ToString("N0")</span>
                    <div class="kpi-trend text-primary">
                        Influenced Sales
                    </div>
                </div>
                <div class="kpi-icon-box">
                    <i class="fas fa-funnel-dollar"></i>
                </div>
            </div>
        </div>

        <!-- Loyalty Revenue Contribution -->
        <div class="col-md-3">
            <div class="kpi-card-premium brand-success">
                <div class="kpi-content">
                    <p class="kpi-title">Loyalty Revenue %</p>
                    <span class="kpi-main-val">@Model.LoyaltyRevenueContributionPercent.ToString("N1")%</span>
                    <div class="kpi-trend text-success">
                        Share of Total Sales
                    </div>
                </div>
                <div class="kpi-icon-box">
                    <i class="fas fa-hand-holding-usd"></i>
                </div>
            </div>
        </div>

        <!-- Retention Rate -->
        <div class="col-md-3">
            <div class="kpi-card-premium brand-indigo">
                <div class="kpi-content">
                    <p class="kpi-title">Retention Rate (%)</p>
                    <span class="kpi-main-val">@Model.RetentionRatePercent.ToString("N1")%</span>
                    <div class="progress mt-2" style="height: 4px; background: rgba(99, 102, 241, 0.2);">
                        <div class="progress-bar bg-indigo" style="width: @Model.RetentionRatePercent%"></div>
                    </div>
                </div>
                <div class="kpi-icon-box">
                    <i class="fas fa-sync"></i>
                </div>
            </div>
        </div>

        <!-- Campaign ROI -->
        <div class="col-md-3">
            <div class="kpi-card-premium brand-danger">
                <div class="kpi-content">
                    <p class="kpi-title">Campaign ROI</p>
                    <span class="kpi-main-val">@($"x{Model.CampaignROI:N1}")</span>
                    <div class="kpi-trend text-danger">
                        Revenue / Discount
                    </div>
                </div>
                <div class="kpi-icon-box">
                    <i class="fas fa-rocket"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- MIDDLE INTELLIGENCE ROW -->
    <div class="row g-4 mb-4">
        <!-- Revenue Trend Chart -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="fw-bold mb-0">Customer Conversion Trend</h6>
                        <p class="text-muted xx-small mb-0">Campaign revenue & acquisition velocity overview</p>
                    </div>
                    <div class="badge bg-soft-blue text-primary rounded-pill px-3">Weekly Strategy</div>
                </div>
                <div class="card-body p-4">
                    <div style="height: 320px;">
                        <canvas id="campaignRevenueTrendChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Acquisition Matrix -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white h-100">
                <div class="card-header bg-white border-0 py-3 px-4">
                    <h6 class="fw-bold mb-0 text-dark">Patron Acquisition Matrix</h6>
                    <p class="text-muted xx-small mb-0">Demographic share & retention behavior</p>
                </div>
                <div class="card-body p-4 pt-0 d-flex flex-column align-items-center justify-content-center">
                    <div class="position-relative" style="height: 220px; width: 100%;">
                        <canvas id="acquisitionDonutChart"></canvas>
                        <div class="position-absolute top-50 start-50 translate-middle text-center">
                            @{
                                var totalActive = Model.NewPatronsCount + Model.ReturningPatronsCount;
                            }
                            <h4 class="fw-bold mb-0">@totalActive</h4>
                            <p class="text-muted xx-small uppercase mb-0">Active</p>
                        </div>
                    </div>
                    
                    <div class="mt-4 w-100">
                         <div class="bg-light rounded-3 p-3 border">
                             <div class="row text-center mb-1">
                                 <div class="col-6 border-end">
                                     <p class="xx-small text-muted text-uppercase mb-0">New</p>
                                     <h6 class="mb-0 fw-bold">@Model.NewPatronsCount</h6>
                                 </div>
                                 <div class="col-6">
                                     <p class="xx-small text-muted text-uppercase mb-0">Returning</p>
                                     <h6 class="mb-0 fw-bold">@Model.ReturningPatronsCount</h6>
                                 </div>
                             </div>
                             <div class="text-center pt-2 border-top">
                                 <p class="xx-small text-muted mb-0">Retention Success: <strong>@Model.RetentionRatePercent.ToString("N1")%</strong></p>
                             </div>
                         </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- STRATEGIC DRILL-DOWN ROW -->
    <div class="row g-4 mb-4">
        <!-- Points Liability Ledger -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white h-100">
                <div class="card-header bg-white border-0 py-3 px-4">
                    <h6 class="fw-bold mb-0 text-dark">Points Issued vs. Redeemed</h6>
                    <p class="text-muted xx-small mb-0">Monitoring loyalty inflation and liability utilization</p>
                </div>
                <div class="card-body p-4 pt-0">
                    <div style="height: 300px;">
                        <canvas id="pointsLedgerChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Strategy Summary & Alerts -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white h-100">
                <div class="card-header bg-white border-0 py-3 px-4">
                    <h6 class="fw-bold mb-0 text-dark">Campaign Impact Ledger</h6>
                    <p class="text-muted xx-small mb-0">Program status & automated intelligence</p>
                </div>
                <div class="card-body p-4 pt-0">
                    <!-- Top/Bottom Performers -->
                    <div class="row g-2 mb-4">
                        <div class="col-6">
                            <div class="p-3 bg-success bg-opacity-10 border border-success border-opacity-20 rounded-3">
                                <p class="xx-small text-success text-uppercase fw-bold mb-1">Top Performer</p>
                                <h6 class="small fw-bold mb-0">@Model.TopCampaignName</h6>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-danger bg-opacity-10 border border-danger border-opacity-20 rounded-3">
                                <p class="xx-small text-danger text-uppercase fw-bold mb-1">Underperforming</p>
                                <h6 class="small fw-bold mb-0">@Model.BottomCampaignName</h6>
                            </div>
                        </div>
                    </div>

                    <!-- Expiring Offers / Alerts -->
                    <div class="mb-0">
                        <p class="xx-small text-muted text-uppercase fw-bold mb-2">Automated Alerts</p>
                        <div class="alert-list">
                            <div class="d-flex align-items-center gap-3 p-3 mb-2 rounded-3 border border-light bg-light bg-opacity-50">
                                <div class="icon-box bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                    <i class="fas fa-clock small"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-0 fw-bold small">System Hub Alert</p>
                                    <p class="xx-small text-muted mb-0">Check expiring offers for renewal.</p>
                                </div>
                                <i class="fas fa-chevron-right xx-small text-muted"></i>
                            </div>
                             <div class="d-flex align-items-center gap-3 p-3 rounded-3 border border-light bg-light bg-opacity-50">
                                <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                    <i class="fas fa-lightbulb small"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-0 fw-bold small">Retention Insight</p>
                                    <p class="xx-small text-muted mb-0">Retention is @Model.RetentionRatePercent.ToString("N1")%. Send re-engagement promo.</p>
                                </div>
                                <i class="fas fa-chevron-right xx-small text-muted"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- BOTTOM SECTION: TIER & VIP REVENUE -->
    <div class="row g-4 mb-4">
        <!-- Tier Distribution -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white h-100">
                <div class="card-header bg-white border-0 py-3 px-4">
                    <h6 class="fw-bold mb-0 text-dark">Loyalty Tier Distribution</h6>
                    <p class="text-muted xx-small mb-0">Weighted by revenue contribution per segment</p>
                </div>
                <div class="card-body p-4 pt-0 d-flex flex-column align-items-center justify-content-center">
                    <div class="position-relative" style="height: 220px; width: 100%;">
                        <canvas id="tierDonutChart"></canvas>
                    </div>
                    <div class="mt-4 w-100">
                         @{
                            var totalTierRev = Model.TierRevenueData.Sum();
                            var topTierVal = Model.TierRevenueData.Any() ? Model.TierRevenueData.Max() : 0;
                            var topTierIdx = Model.TierRevenueData.Any() ? Model.TierRevenueData.IndexOf(topTierVal) : 0;
                            var topTierName = Model.TierLabels.ElementAtOrDefault(topTierIdx) ?? "Patron";
                            var topPct = totalTierRev > 0 ? (topTierVal / totalTierRev * 100) : 0;
                         }
                         <div class="bg-light rounded-3 p-3 text-center border">
                             <p class="small text-muted mb-1 text-uppercase fw-bold x-small">Star Segment</p>
                             <h6 class="mb-0 fw-bold text-dark">@topTierName tier drives @topPct.ToString("N0")% of loyalty revenue.</h6>
                         </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top Revenue Contributors -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white h-100">
                <div class="card-header bg-white border-0 py-3 px-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="fw-bold mb-0 text-dark">Top Loyalty Revenue Contributors</h6>
                        <p class="text-muted xx-small mb-0">Ranking by lifetime spend and order frequency</p>
                    </div>
                    <button class="btn btn-sm btn-light border rounded-pill px-3 xx-small fw-bold">Full Leaderboard</button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-muted xx-small uppercase fw-bold">
                                <tr>
                                    <th class="ps-4 py-3">Patron</th>
                                    <th class="py-3">Points</th>
                                    <th class="py-3">Lifetime Spend</th>
                                    <th class="py-3 text-end pe-4">Visits</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var customer in Model.VIPPerformance.Take(5))
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="avatar-sm rounded-circle bg-soft-blue text-primary d-flex align-items-center justify-content-center fw-bold border" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                                    @customer.FullName.Substring(0, 1)
                                                </div>
                                                <div>
                                                    <div class="fw-bold small">@customer.FullName</div>
                                                    <div class="text-muted xx-small">Last: @(customer.LastVisit?.ToString("MMM dd") ?? "N/A")</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge rounded-pill bg-light text-muted border px-2" style="font-size: 0.6rem;">
                                                @customer.Points.ToString("N0")
                                            </span>
                                        </td>
                                        <td class="small fw-bold text-dark">₱@customer.TotalSpend.ToString("N2")</td>
                                        <td class="text-end pe-4">
                                            <span class="text-muted small">@customer.TransactionCount</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-blue { background-color: rgba(79, 70, 229, 0.05); }
    .bg-indigo { background-color: #6366f1 !important; }
    .text-indigo { color: #6366f1 !important; }
    .xx-small { font-size: 0.65rem; }
    .divider { height: 1px; background: #f1f5f9; margin: 1rem 0; }
    .uppercase { text-transform: uppercase; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js" integrity="sha384-52b3468745678901234567890123456789012345678901234567890123456789" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0" integrity="sha384-52b3468745678901234567890123456789012345678901234567890123456789" crossorigin="anonymous"></script>
    <script>
        Chart.register(ChartDataLabels);

        // Global Chart Defaults
        Chart.defaults.font.family = "'Inter', sans-serif";
        Chart.defaults.color = '#64748b';

        // 1. Campaign Revenue Trend (Line Chart)
        const revenueCtx = document.getElementById('campaignRevenueTrendChart').getContext('2d');
        new Chart(revenueCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.CampaignRevenueTrendLabels)),
                datasets: [
                    {
                        label: 'Campaign Revenue (₱)',
                        data: @Html.Raw(Json.Serialize(Model.CampaignRevenueTrendData)),
                        borderColor: '#4f46e5',
                        backgroundColor: 'rgba(79, 70, 229, 0.05)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointHoverRadius: 8,
                        pointHitRadius: 20,
                        pointBackgroundColor: '#4f46e5',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        yAxisID: 'yRev'
                    },
                    {
                        label: 'Conversions',
                        data: @Html.Raw(Json.Serialize(Model.PerformanceData)),
                        borderColor: '#10b981',
                        borderWidth: 2,
                        borderDash: [5, 5],
                        pointRadius: 0,
                        pointHoverRadius: 4,
                        tension: 0.4,
                        fill: false,
                        yAxisID: 'yConv'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { 
                    legend: { display: true, position: 'top', align: 'end', labels: { usePointStyle: true, font: { size: 10 } } },
                    tooltip: {
                        backgroundColor: 'rgba(255, 255, 255, 0.95)',
                        titleColor: '#1e293b',
                        bodyColor: '#475569',
                        borderColor: '#e2e8f0',
                        borderWidth: 1,
                        padding: 12,
                        boxPadding: 8,
                        usePointStyle: true,
                        callbacks: {
                            label: function(context) {
                                let label = context.dataset.label || '';
                                if (label.includes('₱')) {
                                    return label + ': ₱' + context.parsed.y.toLocaleString();
                                }
                                return label + ': ' + context.parsed.y;
                            }
                        }
                    },
                    datalabels: {
                        display: true,
                        color: (context) => context.chart.config.type === 'doughnut' ? '#fff' : '#64748b',
                        anchor: (context) => context.chart.config.type === 'doughnut' ? 'center' : 'end',
                        align: (context) => context.chart.config.type === 'doughnut' ? 'center' : 'top',
                        font: { weight: 'bold', size: 10 },
                        formatter: (value, context) => {
                            if (context.chart.config.type === 'doughnut') {
                                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                if (total === 0) return '';
                                const percentage = (value / total * 100).toFixed(0);
                                return percentage > 5 ? percentage + '%' : '';
                            }
                            return value;
                        }
                    }
                },
                scales: {
                    yRev: { 
                        type: 'linear', 
                        position: 'left', 
                        beginAtZero: true, 
                        grid: { color: '#f1f5f9' }, 
                        ticks: { callback: (v) => '₱' + v.toLocaleString(), font: { size: 10 } } 
                    },
                    yConv: { 
                        type: 'linear', 
                        position: 'right', 
                        beginAtZero: true, 
                        grid: { display: false }, 
                        ticks: { font: { size: 10 } } 
                    },
                    x: { grid: { display: false }, ticks: { font: { size: 10 } } }
                }
            }
        });

        // 2. Acquisition Matrix (Donut Chart)
        const acqCtx = document.getElementById('acquisitionDonutChart').getContext('2d');
        new Chart(acqCtx, {
            type: 'doughnut',
            data: {
                labels: ['New', 'Returning'],
                datasets: [{
                    data: [@Model.NewPatronsCount, @Model.ReturningPatronsCount],
                    backgroundColor: ['#4f46e5', '#e2e8f0'],
                    borderWidth: 2,
                    borderColor: '#fff',
                    hoverOffset: 15
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '80%',
                plugins: {
                    legend: { 
                        display: true, 
                        position: 'bottom',
                        labels: {
                            usePointStyle: true,
                            font: { size: 10, weight: 'bold' },
                            generateLabels: function(chart) {
                                const data = chart.data;
                                if (data.labels.length && data.datasets.length) {
                                    const dataset = data.datasets[0];
                                    const total = dataset.data.reduce((a, b) => a + b, 0);
                                    return data.labels.map((label, i) => {
                                        const value = dataset.data[i];
                                        const percentage = total > 0 ? ((value / total) * 100).toFixed(0) : 0;
                                        return {
                                            text: `${label} (${percentage}%)`,
                                            fillStyle: dataset.backgroundColor[i],
                                            strokeStyle: dataset.backgroundColor[i],
                                            lineWidth: 0,
                                            index: i
                                        };
                                    });
                                }
                                return [];
                            }
                        }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(255, 255, 255, 0.95)',
                        titleColor: '#1e293b',
                        bodyColor: '#475569',
                        borderColor: '#e2e8f0',
                        borderWidth: 1,
                        padding: 10,
                        callbacks: {
                            label: function(item) {
                                let total = item.dataset.data.reduce((a, b) => a + b, 0);
                                let percentage = Math.round((item.raw / total) * 100);
                                return `${item.label}: ${item.raw} (${percentage}%)`;
                            }
                        }
                    },
                    datalabels: {
                        display: true,
                        color: (context) => context.chart.config.type === 'doughnut' ? '#fff' : '#64748b',
                        anchor: (context) => context.chart.config.type === 'doughnut' ? 'center' : 'end',
                        align: (context) => context.chart.config.type === 'doughnut' ? 'center' : 'top',
                        font: { weight: 'bold', size: 10 },
                        formatter: (value, context) => {
                            if (context.chart.config.type === 'doughnut') {
                                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                if (total === 0) return '';
                                const percentage = (value / total * 100).toFixed(0);
                                return percentage > 5 ? percentage + '%' : '';
                            }
                            return value;
                        }
                    }
                }
            }
        });

        // 3. Points Ledger (Issued vs Redeemed - Bar Chart)
        const pointsCtx = document.getElementById('pointsLedgerChart').getContext('2d');
        new Chart(pointsCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.PointsTrendLabels)),
                datasets: [
                    {
                        label: 'Points Issued',
                        data: @Html.Raw(Json.Serialize(Model.PointsIssuedData)),
                        backgroundColor: '#4f46e5',
                        borderRadius: 4,
                        hoverBackgroundColor: '#4338ca'
                    },
                    {
                        label: 'Points Redeemed',
                        data: @Html.Raw(Json.Serialize(Model.PointsRedeemedData)),
                        backgroundColor: '#fbbf24',
                        borderRadius: 4,
                        hoverBackgroundColor: '#d97706'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { 
                    legend: { position: 'top', align: 'end', labels: { usePointStyle: true, font: { size: 11 } } },
                    tooltip: {
                        backgroundColor: 'rgba(255, 255, 255, 0.95)',
                        titleColor: '#1e293b',
                        bodyColor: '#475569',
                        borderColor: '#e2e8f0',
                        borderWidth: 1,
                        padding: 10
                    },
                    datalabels: {
                        display: true,
                        color: (context) => context.chart.config.type === 'doughnut' ? '#fff' : '#64748b',
                        anchor: (context) => context.chart.config.type === 'doughnut' ? 'center' : 'end',
                        align: (context) => context.chart.config.type === 'doughnut' ? 'center' : 'top',
                        font: { weight: 'bold', size: 10 },
                        formatter: (value, context) => {
                            if (context.chart.config.type === 'doughnut') {
                                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                if (total === 0) return '';
                                const percentage = (value / total * 100).toFixed(0);
                                return percentage > 5 ? percentage + '%' : '';
                            }
                            return value;
                        }
                    }
                },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { font: { size: 10 } } },
                    x: { grid: { display: false }, ticks: { font: { size: 10 } } }
                }
            }
        });

        // 4. Loyalty Tier Distribution (Donut Chart)
        const tierCtx = document.getElementById('tierDonutChart').getContext('2d');
        const tierRevenueData = @Html.Raw(Json.Serialize(Model.TierRevenueData));
        new Chart(tierCtx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.TierLabels)),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.TierData)),
                    backgroundColor: ['#f59e0b', '#6366f1', '#94a3b8', '#e2e8f0'],
                    borderWidth: 2,
                    borderColor: '#fff',
                    hoverOffset: 20
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: {
                    legend: { 
                        position: 'bottom', 
                        labels: { 
                            usePointStyle: true, 
                            font: { size: 10, weight: 'bold' },
                            generateLabels: function(chart) {
                                const data = chart.data;
                                if (data.labels.length && data.datasets.length) {
                                    const dataset = data.datasets[0];
                                    const total = dataset.data.reduce((a, b) => a + b, 0);
                                    return data.labels.map((label, i) => {
                                        const value = dataset.data[i];
                                        const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                        return {
                                            text: `${label} (${percentage}%)`,
                                            fillStyle: dataset.backgroundColor[i],
                                            strokeStyle: dataset.backgroundColor[i],
                                            lineWidth: 0,
                                            index: i
                                        };
                                    });
                                }
                                return [];
                            }
                        } 
                    },
                    tooltip: {
                        backgroundColor: 'rgba(255, 255, 255, 0.95)',
                        titleColor: '#1e293b',
                        bodyColor: '#475569',
                        borderColor: '#e2e8f0',
                        borderWidth: 1,
                        padding: 12,
                        callbacks: {
                            label: function(item) {
                                let val = item.raw || 0;
                                let revenue = tierRevenueData[item.dataIndex] || 0;
                                const total = item.dataset.data.reduce((a, b) => a + b, 0);
                                const percentage = ((val / total) * 100).toFixed(1);
                                return [
                                    `${item.label}: ${val} (${percentage}%)`, 
                                    `Weighted Revenue: ₱${revenue.toLocaleString()}`
                                ];
                            }
                        }
                    },
                    datalabels: {
                        display: true,
                        color: (context) => context.chart.config.type === 'doughnut' ? '#fff' : '#64748b',
                        anchor: (context) => context.chart.config.type === 'doughnut' ? 'center' : 'end',
                        align: (context) => context.chart.config.type === 'doughnut' ? 'center' : 'top',
                        font: { weight: 'bold', size: 10 },
                        formatter: (value, context) => {
                            if (context.chart.config.type === 'doughnut') {
                                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                if (total === 0) return '';
                                const percentage = (value / total * 100).toFixed(0);
                                return percentage > 5 ? percentage + '%' : '';
                            }
                            return value;
                        }
                    }
                }
            }
        });
    </script>
}
