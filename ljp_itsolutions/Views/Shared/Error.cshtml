@model ErrorViewModel
@{
    ViewData["Title"] = "System Error";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card border-0 shadow-lg rounded-4 p-5">
                <div class="mb-4">
                    <i class="fas fa-exclamation-triangle text-danger" style="font-size: 5rem;"></i>
                </div>
                <h1 class="fw-bold text-dark mb-3">An Unexpected Error Occurred</h1>
                <p class="text-muted lead mb-4">
                    For your security, technical details about this event have been logged internally and concealed from this view.
                </p>
                <div class="bg-light p-4 rounded-3 mb-4">
                    <p class="mb-2 fw-bold text-primary">Next Steps:</p>
                    <ul class="text-start d-inline-block small text-muted">
                        <li>Please contact your **System Administrator** or the IT Department.</li>
                        <li>Provide your Username and the time this error occurred.</li>
                        <li>Reference Request ID: <code class="text-danger">@Model.RequestId</code></li>
                    </ul>
                </div>
                <div class="d-flex gap-2 justify-content-center">
                    <a href="/" class="btn btn-primary rounded-pill px-5">Return Dashboard</a>
                    <a href="mailto:itsolutionslj@gmail.com" class="btn btn-outline-secondary rounded-pill px-4">Contact Support</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8f9fa; }
    .card { border-top: 5px solid #dc3545 !important; }
</style>
