@model ljp_itsolutions.Models.Order
<div class="modal-content border-0 shadow-lg rounded-4">
    <div class="modal-header bg-primary text-white border-0">
        <div class="d-flex align-items-center gap-3">
            <div class="avatar-sm bg-white bg-opacity-20 rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                <i class="fas fa-receipt"></i>
            </div>
            <div>
                <h6 class="modal-title fw-bold mb-0">Order Receipt</h6>
                <p class="mb-0 x-small text-white text-opacity-75 uppercase tracking-wider" id="modalOrderId">#@Model?.OrderID.ToString().Substring(0, 8)</p>
            </div>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body p-0">
        <!-- Receipt Details -->
        <div class="p-4 bg-light border-bottom">
            <div class="row g-3">
                <div class="col-6">
                    <p class="x-small text-muted uppercase tracking-wider mb-1">Customer</p>
                    <div class="fw-bold text-dark" id="modalCustomer">@(Model?.Customer?.FullName ?? "Walk-in Customer")</div>
                </div>
                <div class="col-6 text-end">
                    <p class="x-small text-muted uppercase tracking-wider mb-1">Date & Time</p>
                    <div class="fw-bold text-dark" id="modalDate">@Model?.OrderDate.ToString("MMM dd, yyyy hh:mm tt")</div>
                </div>
                <div class="col-6">
                    <p class="x-small text-muted uppercase tracking-wider mb-1">Cashier</p>
                    <div class="fw-bold text-dark" id="modalCashier">@(Model?.Cashier?.FullName ?? "N/A")</div>
                </div>
                <div class="col-6 text-end">
                    <p class="x-small text-muted uppercase tracking-wider mb-1">Payment Method</p>
                    <div class="badge bg-white text-dark border shadow-sm" id="modalPayment">@Model?.PaymentMethod</div>
                </div>
            </div>
        </div>
        
        <!-- Items List -->
        <div class="p-4" style="max-height: 300px; overflow-y: auto;">
            <p class="x-small text-muted uppercase tracking-wider mb-3">Order Items</p>
            <div id="modalItemsList" class="d-flex flex-column gap-3">
                @if (Model?.OrderDetails != null)
                {
                    foreach (var item in Model.OrderDetails)
                    {
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar-xs bg-light rounded px-2 py-1 small fw-bold text-muted">@item.Quantity x</div>
                                <div>
                                    <div class="fw-medium text-dark">@item.Product.ProductName</div>
                                    <div class="x-small text-muted">@@ ₱@item.UnitPrice.ToString("N2")</div>
                                </div>
                            </div>
                            <div class="fw-bold text-dark">₱@item.Subtotal.ToString("N2")</div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Total -->
        <div class="p-4 bg-light border-top">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="text-muted uppercase tracking-wider small">Status</span>
                <div id="modalStatusBadge">
                    @if (Model?.PaymentStatus == "Paid" || Model?.PaymentStatus == "Completed" || Model?.PaymentStatus == "Paid (Digital)")
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-10 px-3">PAID</span>
                    }
                    else
                    {
                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-10 px-3">@Model?.PaymentStatus.ToUpper()</span>
                    }
                </div>
            </div>
            @if (Model?.DiscountAmount > 0)
            {
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="text-muted uppercase tracking-wider small">Discount</span>
                    <span class="fw-bold text-danger">-₱@Model.DiscountAmount.ToString("N2")</span>
                </div>
            }
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted uppercase tracking-wider small">Total Amount</span>
                <h4 class="fw-bold text-primary mb-0" id="modalTotal">₱@Model?.FinalAmount.ToString("N2")</h4>
            </div>
        </div>
    </div>
    <div class="modal-footer border-0 p-3 pt-0">
        <div class="d-flex gap-2 w-100 mb-2" id="modalControls">
            <!-- Controls injected or shown based on role -->
        </div>
        <div class="d-flex gap-2 w-100">
            <button type="button" class="btn btn-light rounded-pill px-4 fw-bold flex-fill" data-bs-dismiss="modal">Close</button>
            <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold flex-fill" onclick="window.print()">
                <i class="fas fa-print me-2"></i>Print
            </button>
        </div>
    </div>
</div>
