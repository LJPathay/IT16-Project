@using System.Security.Claims
@* Default application layout (authenticated) *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @{
        var pageTitle = ViewData["Title"]?.ToString();
        var brandName = "Coffee LJP";
        var finalTitle = string.IsNullOrEmpty(pageTitle) || pageTitle.Contains(brandName) ? brandName : $"{pageTitle} | {brandName}";
    }
    <title>@finalTitle</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <!-- Premium Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha384-iw3OoTErCYJJB9mCa8LNS2hbsQ7M3C0EpIsO/H5+EGAkPGc6rk+V8i04oW/K5xq0" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" integrity="sha384-Gu3KVV2H9d+yA4QDpVB7VcOyhJlAVrcXd0thEjr4KznfaFPLe0xQJyonVxONa4ZC" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/manager-styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var username = Context.Session.GetString("Username") ?? User.Identity?.Name ?? "guest";
        var fullName = Context.Session.GetString("FullName") ?? username;
        var userRole = Context.Session.GetString("UserRole") ?? User.FindFirst(ClaimTypes.Role)?.Value ?? "-";
        var profilePic = Context.Session.GetString("ProfilePictureUrl");
        var initials = string.Join("", fullName.Split(' ').Select(n => n.Length > 0 ? n[0].ToString() : "")).ToUpper();
        if (string.IsNullOrEmpty(initials)) initials = username.Substring(0, 1).ToUpper();
        
        // Accessibility Settings
        var isHighContrast = Context.Session.GetString("IsHighContrast") == "true";
        var fontSize = Context.Session.GetString("FontSize") ?? "default";
        var reduceMotion = Context.Session.GetString("ReduceMotion") == "true";

        var accessibilityClasses = $"{(isHighContrast ? "access-high-contrast" : "")} access-font-{fontSize} {(reduceMotion ? "access-reduce-motion" : "")}";
    }
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <div class="app d-flex @accessibilityClasses">
        <aside class="sidebar p-3 d-flex flex-column">
            <div class="brand mb-4">
                <div class="d-flex align-items-center justify-content-center mb-3">
                    <img src="@(Url.Content("~/images/logo.png"))" alt="Coffee LJP" class="sidebar-logo" />
                </div>
            </div>
            <nav class="nav flex-column gap-2 h-100">
                @if (IsSectionDefined("Navigation"))
                {
                    @RenderSection("Navigation")
                }
                else if (string.Equals(userRole, "SuperAdmin", StringComparison.OrdinalIgnoreCase))
                {
                    <partial name="_SuperAdminNavigation" />
                }
                else if (string.Equals(userRole, "Cashier", StringComparison.OrdinalIgnoreCase))
                {
                    <partial name="_CashierNavigation" />
                }
                else if (string.Equals(userRole, "MarketingStaff", StringComparison.OrdinalIgnoreCase) || ViewContext.RouteData.Values["controller"]?.ToString() == "Marketing")
                {
                    <partial name="_MarketingNavigation" />
                }
                else if (string.Equals(userRole, "Manager", StringComparison.OrdinalIgnoreCase) || ViewContext.RouteData.Values["controller"]?.ToString() == "Manager")
                {
                    <partial name="_ManagerNavigation" />
                }
                else if (string.Equals(userRole, "Admin", StringComparison.OrdinalIgnoreCase) || ViewContext.RouteData.Values["controller"]?.ToString() == "Admin")
                {
                    <partial name="_AdminNavigation" />
                }
                else
                {
                    <a class="nav-link active" href="/Admin/Dashboard">Dashboard</a>
                    <a class="nav-link" href="/Admin/Users">User & Access Management</a>
                    <a class="nav-link" href="/Admin/Reports">CRM</a>
                    <a class="nav-link" href="/POS/Index">POS & Orders</a>
                    <a class="nav-link" href="/Manager/Products">Product & Menu</a>
                    <a class="nav-link" href="/Marketing/Promotions">Marketing Automation</a>
                    <a class="nav-link" href="/Manager/Reports">Business Intelligence</a>
                    <a class="nav-link" href="/Admin/Reports">Finance & Budget</a>
                    <a class="nav-link" href="/Manager/Inventory">Inventory Management</a>
                }
            </nav>
        </aside>

        <main class="content flex-fill">

            <div class="layout-header bg-white shadow-sm border-bottom px-4 py-3">
                <header class="d-flex justify-content-between align-items-center">
                <div class="header-left d-flex align-items-center gap-3">
                    <button class="btn btn-link link-dark d-lg-none p-0 border-0" id="sidebarToggle">
                        <i class="fas fa-bars fa-lg"></i>
                    </button>
                    <div class="header-brand d-lg-none">
                        <img src="~/images/logo.png" alt="Coffee LJP" height="30">
                    </div>
                    <div>
                        <h1 class="h4 mb-0 fw-bold text-dark tracking-tight">@ViewData["Title"]</h1>
                        <div class="text-muted x-small d-flex align-items-center gap-2 mt-1">
                            @if (ViewData["Subtitle"] != null)
                            {
                                <span>@ViewData["Subtitle"]</span>
                            }
                            else
                            {
                                <i class="far fa-calendar-alt opacity-50"></i>
                                <span>@DateTime.Now.ToString("dddd, MMMM d, yyyy")</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="header-right d-flex align-items-center gap-3">
                    <!-- Notifications -->
                    @if (userRole == "Admin" || userRole == "Manager" || userRole == "MarketingStaff")
                    {
                        <vc:notifications />
                    }

                    <!-- Page Actions -->
                    @await RenderSectionAsync("HeaderActions", required: false)

                    <!-- User Profile -->
                    <div class="dropdown">
                        <button class="btn btn-profile d-flex align-items-center gap-3 shadow-none border-0 bg-transparent p-0" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="profile-avatar bg-amber text-white d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px; border-radius: 50%; font-weight: bold; overflow: hidden;">
                                @if (!string.IsNullOrEmpty(profilePic))
                                {
                                    <img src="@profilePic" alt="@fullName" style="width:100%; height:100%; object-fit:cover;" />
                                }
                                else
                                {
                                    <span>@initials</span>
                                }
                            </div>
                            <div class="text-start d-none d-md-block">
                                <p class="mb-0 small fw-bold text-dark">@fullName</p>
                                <p class="mb-0 x-small text-muted fw-bold">Role: @userRole</p>
                            </div>
                            <i class="fas fa-chevron-down x-small text-muted ms-1"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2">
                            @if (User?.Identity?.IsAuthenticated == true)
                            {
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2 py-2" asp-controller="Account" asp-action="Profile">
                                        <i class="fas fa-user-cog opacity-75"></i>
                                        <span>Profile & Settings</span>
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider opacity-50"></li>
                                <li>
                                    <form method="post" asp-controller="Account" asp-action="Logout" id="logoutForm">
                                        <button type="submit" class="dropdown-item text-danger d-flex align-items-center gap-2 py-2 w-100">
                                            <i class="fas fa-sign-out-alt opacity-75"></i>
                                            <span>Sign Out</span>
                                        </button>
                                    </form>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </header>
            </div>

            <div class="layout-body p-4">
                <section>
                @RenderBody()
                </section>
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js" integrity="sha384-jb8JQMbMoBUzgWatfe6COACi2ljcDdZQ2OxczGA3bGNeWe+6DChMTBJemed7ZnvJ" crossorigin="anonymous"></script>
    <script src="~/js/dashboard.js"></script>
    <script>
        function showToast(message, type = 'success') {
            const toastId = 'toast-' + Date.now();
            const isSuccess = type === 'success';
            
            // Premium CSS for the Wow Factor
            const toastHtml = `
                <div id="${toastId}" class="position-fixed bottom-0 end-0 p-4" style="z-index: 9999; max-width: 400px; pointer-events: none;">
                    <div class="toast-wow-card animate__animated animate__backInUp" style="pointer-events: auto;">
                        <!-- Skeleton Phase -->
                        <div class="skeleton-content">
                            <div class="shimmer-circle"></div>
                            <div class="shimmer-lines">
                                <div class="shimmer-line short"></div>
                                <div class="shimmer-line long"></div>
                            </div>
                        </div>
                        
                        <!-- Actual Content (Hidden initially) -->
                        <div class="actual-content" style="display: none;">
                            <div class="success-icon-wrapper ${isSuccess ? 'bg-gold-glow' : 'bg-danger-glow'}">
                                <i class="fas ${isSuccess ? 'fa-check-circle' : 'fa-times-circle'} animate__animated animate__rotateIn"></i>
                            </div>
                            <div class="success-text">
                                <h6 class="mb-0 fw-bold text-dark">${isSuccess ? 'Operation Successful' : 'Action Failed'}</h6>
                                <p class="mb-0 text-muted x-small">${message}</p>
                            </div>
                            <button type="button" class="btn-close ms-2" onclick="this.closest('.position-fixed').remove()" style="font-size: 0.7rem;"></button>
                        </div>
                    </div>
                </div>

                <style>
                    .toast-wow-card {
                        background: rgba(255, 255, 255, 0.85);
                        backdrop-filter: blur(20px);
                        -webkit-backdrop-filter: blur(20px);
                        border: 1px solid rgba(255, 255, 255, 0.4);
                        border-left: 6px solid ${isSuccess ? '#FFD700' : '#FF4D4D'};
                        border-radius: 1.5rem;
                        padding: 1.25rem 1.5rem;
                        box-shadow: 0 20px 40px rgba(0,0,0,0.12), 0 0 20px ${isSuccess ? 'rgba(212, 175, 55, 0.2)' : 'rgba(220, 53, 69, 0.1)'};
                        display: flex;
                        align-items: center;
                        gap: 1.25rem;
                        min-width: 350px;
                        overflow: hidden;
                        position: relative;
                    }
                    .skeleton-content { 
                        display: flex; 
                        align-items: center; 
                        gap: 1rem; 
                        width: 100%; 
                    }
                    .shimmer-circle { width: 48px; height: 48px; border-radius: 50%; background: #e2e8f0; position: relative; overflow: hidden; flex-shrink: 0; }
                    .shimmer-circle::after, .shimmer-line::after {
                        content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
                        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.7), transparent);
                        animation: shimmerMove 1.5s infinite;
                    }
                    .shimmer-lines { flex-grow: 1; }
                    .shimmer-line { height: 10px; background: #e2e8f0; border-radius: 5px; margin-bottom: 10px; position: relative; overflow: hidden; }
                    .shimmer-line.long { width: 90%; }
                    .shimmer-line.short { width: 60%; }
                    
                    @@keyframes shimmerMove { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
                    
                    .bg-gold-glow { 
                        background: linear-gradient(135deg, #FFD700, #FFA500); 
                        color: #1a1a1a; 
                        display:flex; align-items:center; justify-content:center; 
                        width: 48px; height: 48px; border-radius: 50%; 
                        box-shadow: 0 8px 16px rgba(255, 165, 0, 0.3); 
                        font-size: 1.4rem; 
                        flex-shrink: 0;
                    }
                    .bg-danger-glow { 
                        background: linear-gradient(135deg, #FF4B2B, #FF416C); 
                        color: white; 
                        display:flex; align-items:center; justify-content:center; 
                        width: 48px; height: 48px; border-radius: 50%; 
                        box-shadow: 0 8px 16px rgba(255, 75, 43, 0.3); 
                        font-size: 1.4rem; 
                        flex-shrink: 0;
                    }
                    .success-text h6 { font-family: 'Outfit', sans-serif; letter-spacing: -0.02em; }
                    .actual-content { display: flex !important; align-items: center; gap: 1.25rem; width: 100%; animation: animate__fadeIn 0.6s both; }
                </style>
            `;
            
            document.body.insertAdjacentHTML('beforeend', toastHtml);
            
            const toastElement = document.getElementById(toastId);
            const skeleton = toastElement.querySelector('.skeleton-content');
            const actual = toastElement.querySelector('.actual-content');
            
            // Reveal content after a short 'loading' delay to show off the skeleton
            setTimeout(() => {
                skeleton.style.display = 'none';
                actual.style.display = 'flex';
            }, 800);

            // Auto-remove after 5 seconds
            setTimeout(() => {
                if (toastElement) {
                    toastElement.querySelector('.toast-wow-card').classList.replace('animate__backInUp', 'animate__fadeOutDown');
                    setTimeout(() => toastElement.remove(), 800);
                }
            }, 6000);
        }
    </script>
    <script>
        // Automatic Inactivity Timeout (20 Minutes)
        let idleTimer;
        function resetTimer() {
            clearTimeout(idleTimer);
            /* 1,200,000 ms = 20 minutes */
            idleTimer = setTimeout(() => {
                const logoutForm = document.getElementById('logoutForm');
                if (logoutForm) {
                    console.warn("Session timeout due to inactivity. Logging out.");
                    logoutForm.submit();
                } else {
                    window.location.href = '/Account/Login?msg=SessionExpired';
                }
            }, 1200000); 
        }

        // List of events to reset the timer
        window.onload = resetTimer;
        window.onmousemove = resetTimer;
        window.onmousedown = resetTimer;
        window.ontouchstart = resetTimer;
        window.onclick = resetTimer;
        window.onkeydown = resetTimer;
        window.addEventListener('scroll', resetTimer, true);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    @if (TempData["SuccessMessage"] != null || TempData["Success"] != null || TempData["Message"] != null)
    {
        var msg = TempData["SuccessMessage"] ?? TempData["Success"] ?? TempData["Message"];
        <script>
            window.addEventListener('load', () => {
                showToast("@msg", 'success');
            });
        </script>
    }
    @if (TempData["ErrorMessage"] != null || TempData["Error"] != null)
    {
        var msg = TempData["ErrorMessage"] ?? TempData["Error"];
        <script>
            window.addEventListener('load', () => {
                showToast("@msg", 'error');
            });
        </script>
    }
</body>
</html>
